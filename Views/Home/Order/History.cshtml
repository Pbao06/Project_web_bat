@model IEnumerable<Getdata1.DTOs.OrderDto>
@{
    ViewData["Title"] = "Lịch sử mua hàng";
}

<div class="container mt-5">
    <h2 class="mb-4">Đơn hàng của bạn</h2>

    @if (Model.Any())
    {
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>Mã đơn</th>
                            <th>Ngày đặt</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td class="fw-bold text-primary">#@order.Id</td>
                                <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@order.TotalPrice.ToString("C0")</td>
                                <td>
                                    <span class="badge @(order.Status == Getdata1.Models.Enums.OrderStatus.Pending ? "bg-warning" : "bg-success")">
                                        @order.Status
                                    </span>
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-outline-primary btn-sm rounded-pill px-3">Chi tiết</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <h3>Bạn chưa có đơn hàng nào</h3>
            <a asp-area="User" asp-controller="Store" asp-action="Index" class="btn btn-primary mt-3">Mua ngay</a>
        </div>
    }
</div>