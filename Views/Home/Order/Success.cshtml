@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container mt-5 pt-5 text-center">
    <div class="mb-4">
        <i class="bi bi-check-circle-fill display-1 text-success"></i>
    </div>
    <h1 class="display-4 fw-bold">Đặt hàng thành công!</h1>
    <p class="lead text-muted mb-5">Cảm ơn bạn đã tin tưởng Badminton Store. Chúng tôi sẽ sớm liên hệ để giao hàng.</p>
    
    <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
        <a asp-area="User" asp-controller="Store" asp-action="Index" class="btn btn-primary btn-lg px-4 gap-3 shadow-sm">Tiếp tục mua sắm</a>
        <a asp-action="History" class="btn btn-outline-secondary btn-lg px-4 shadow-sm">Xem đơn hàng của tôi</a>
    </div>
</div>