<!-- MAIN CONTACT LAYOUT -->
<div class="contact-wrap">

    <!-- FORM -->
    <div class="contact-form-side">
        <span class="form-label-top">Send a Message</span>
        <h2 class="form-title">How can we help?</h2>
        <p class="form-subtitle">Pick a topic below so we can route your message to the right specialist.</p>

        <!-- Topic pills -->
        <div class="topic-pills">
            <div class="pill active" onclick="selectPill(this)">Order & Shipping</div>
            <div class="pill" onclick="selectPill(this)">Product Advice</div>
            <div class="pill" onclick="selectPill(this)">Stringing Service</div>
            <div class="pill" onclick="selectPill(this)">Returns & Warranty</div>
            <div class="pill" onclick="selectPill(this)">Partnership</div>
            <div class="pill" onclick="selectPill(this)">Other</div>
        </div>

        <!-- Form -->
        <div class="form-row">
            <div class="form-group">
                <label>First Name *</label>
                <input type="text" placeholder="Nguyễn" id="fname">
            </div>
            <div class="form-group">
                <label>Last Name *</label>
                <input type="text" placeholder="Thanh" id="lname">
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Email *</label>
                <input type="email" placeholder="you@email.com" id="email">
            </div>
            <div class="form-group">
                <label>Phone (optional)</label>
                <input type="tel" placeholder="+84 900 000 000" id="phone">
            </div>
        </div>

        <div class="form-group">
            <label>Order Number (if applicable)</label>
            <input type="text" placeholder="PB-2026-XXXXX" id="order">
        </div>

        <div class="form-group">
            <label>Message *</label>
            <textarea placeholder="Tell us what's on your mind — the more detail, the faster we can help." id="msg" oninput="updateChar()"></textarea>
            <div class="char-count" id="charCount">0 / 500</div>
        </div>

        <div class="form-group">
            <label>Rate your recent experience (optional)</label>
            <div class="star-rating" id="stars">
                <i class='bx bx-star' onclick="setRating(1)"></i>
                <i class='bx bx-star' onclick="setRating(2)"></i>
                <i class='bx bx-star' onclick="setRating(3)"></i>
                <i class='bx bx-star' onclick="setRating(4)"></i>
                <i class='bx bx-star' onclick="setRating(5)"></i>
            </div>
        </div>

        <button class="btn-submit" onclick="submitForm()">
            Send Message <i class='bx bx-send'></i>
        </button>

        <div class="success-msg" id="successMsg">
            <i class='bx bx-check-circle'></i>
            <p><strong>Message sent!</strong> Our team will get back to you within 24 hours. Check your inbox for a confirmation email.</p>
        </div>
    </div>

    <!-- INFO CARDS -->
    <div class="contact-info-side">

        <div class="info-card">
            <div class="info-card-head">
                <div class="info-icon"><i class='bx bx-map-pin'></i></div>
                <h3>Visit Our Store</h3>
            </div>
            <p>123 Nguyễn Huệ Boulevard<br>District 1, Ho Chi Minh City<br>Vietnam, 700000</p>
            <a href="#" class="info-link">Get Directions <i class='bx bx-right-arrow-alt'></i></a>
        </div>

        <div class="info-card">
            <div class="info-card-head">
                <div class="info-icon"><i class='bx bx-time'></i></div>
                <h3>Opening Hours</h3>
            </div>
            <div class="hours-list">
                <div class="hours-row"><span class="day">Mon – Fri</span><span class="time">8:00 – 21:00</span></div>
                <div class="hours-row"><span class="day">Saturday</span><span class="time">8:00 – 22:00</span></div>
                <div class="hours-row"><span class="day">Sunday</span><span class="time">9:00 – 20:00</span></div>
                <div class="hours-row"><span class="day">Public Holiday</span><span class="time closed">Closed</span></div>
            </div>
        </div>

        <div class="info-card">
            <div class="info-card-head">
                <div class="info-icon"><i class='bx bx-phone'></i></div>
                <h3>Call or Email</h3>
            </div>
            <p>Prefer to talk? Reach us directly.</p>
            <a href="tel:+842812345678" class="info-link"><i class='bx bx-phone' style="font-size:14px"></i> +84 28 1234 5678</a><br>
            <a href="mailto:hello@pbao.com" class="info-link"><i class='bx bx-envelope' style="font-size:14px"></i> hello@pbao.com</a>
        </div>

        <div class="info-card">
            <div class="info-card-head">
                <div class="info-icon"><i class='bx bx-chat'></i></div>
                <h3>Follow Us</h3>
            </div>
            <p>Stay updated on new drops & court tips.</p>
            <div class="social-row">
                <a href="#" class="social-btn" title="Facebook"><i class='bx bxl-facebook'></i></a>
                <a href="#" class="social-btn" title="Instagram"><i class='bx bxl-instagram'></i></a>
                <a href="#" class="social-btn" title="TikTok"><i class='bx bxl-tiktok'></i></a>
                <a href="#" class="social-btn" title="YouTube"><i class='bx bxl-youtube'></i></a>
            </div>
        </div>

    </div>
</div>

<!-- FAQ -->
<div class="faq-section">
    <div class="faq-inner">
        <span class="faq-label">Common Questions</span>
        <h2 class="faq-title">Quick Answers</h2>

        <div class="faq-item">
            <button class="faq-q" onclick="toggleFaq(this)">
                How long does shipping take within Vietnam?
                <i class='bx bx-chevron-down'></i>
            </button>
            <div class="faq-a">Standard delivery within Ho Chi Minh City takes 1–2 business days. For other provinces, please allow 3–5 business days. Express same-day delivery is available in District 1–12. Orders above 2.000.000 đ ship free.</div>
        </div>

        <div class="faq-item">
            <button class="faq-q" onclick="toggleFaq(this)">
                Can I get my racket strung at the store?
                <i class='bx bx-chevron-down'></i>
            </button>
            <div class="faq-a">Yes! Walk-ins are welcome for our professional stringing service. Standard restring takes 30–60 minutes in-store. We carry over 40 string types and can string to your preferred tension. Prices start from 80,000 VND per racket.</div>
        </div>

        <div class="faq-item">
            <button class="faq-q" onclick="toggleFaq(this)">
                What is your return & exchange policy?
                <i class='bx bx-chevron-down'></i>
            </button>
            <div class="faq-a">We accept returns within 14 days of purchase for unused items in original packaging. Defective products are covered by the manufacturer's warranty (1–2 years depending on brand). Please contact us with your order number to start the process.</div>
        </div>

        <div class="faq-item">
            <button class="faq-q" onclick="toggleFaq(this)">
                Do you offer bulk or club discounts?
                <i class='bx bx-chevron-down'></i>
            </button>
            <div class="faq-a">Absolutely. We have special pricing for badminton clubs, academies, and team orders of 10+ items. Reach out via the contact form and select "Partnership" as your topic — our team will get back with a custom quote within 24 hours.</div>
        </div>

        <div class="faq-item">
            <button class="faq-q" onclick="toggleFaq(this)">
                Are all products on the site authentic?
                <i class='bx bx-chevron-down'></i>
            </button>
            <div class="faq-a">100%. We are an official authorised dealer for Yonex, Victor, Li-Ning, and Apacs. All products come with official authenticity seals and full manufacturer warranty. We never stock grey-market or replica products.</div>
        </div>
    </div>
</div>
