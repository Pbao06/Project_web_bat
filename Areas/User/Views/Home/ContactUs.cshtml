    /* Char count */
    function updateChar(){
      const v = document.getElementById('msg').value.length;
      document.getElementById('charCount').textContent = v + ' / 500';
    }

    /* Star rating */
    let rating = 0;
    function setRating(n){
      rating = n;
      document.querySelectorAll('#stars i').forEach((s,i)=>{
        s.className = i < n ? 'bx bxs-star' : 'bx bx-star';
        s.style.color = i < n ? '#f5a623' : 'var(--bg3)';
      });
    }

