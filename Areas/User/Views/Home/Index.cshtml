@section Scripts {
    <script src="~/js/favorite.js"></script>
    <script>
        /* ── Draw racket strings ── */
        const fs = document.getElementById('fStrings');
        if(fs){
          for(let i=0;i<=6;i++){const v=document.createElement('div');v.className='r-sv';v.style.left=(i*16)+'px';fs.appendChild(v);}
          for(let i=0;i<=8;i++){const h=document.createElement('div');h.className='r-sh';h.style.top=(i*16)+'px';fs.appendChild(h);}
        }

        /* ── Product data ── */
        const PRODUCTS = @Html.Raw(Json.Serialize(Model?.Select(p => new {
                id = p.Id,
                name = p.Name,
                price = p.Price,
                oldPrice = (decimal?)null,
                rating = p.AverageRating > 0 ? p.AverageRating : 4.5,
                reviews = p.ReviewCount > 0 ? p.ReviewCount : (p.Stock % 50 + 10),
                badge = (DateTime.UtcNow - (p.CreatedAt ?? DateTime.UtcNow)).TotalDays < 30 ? "new" : "",
                icon = "bx-baseball",
                isNew = (DateTime.UtcNow - (p.CreatedAt ?? DateTime.UtcNow)).TotalDays < 30,
                image = p.Image,
                cat = p.CategoryName ?? "Sản phẩm",
                brand = p.Brand,
                isLiked = p.IsLiked
            }) ?? Enumerable.Empty<object>()));

        // Khởi tạo tập hợp các sản phẩm đã thích từ Model
        let wished = new Set(PRODUCTS.filter(p => p.isLiked).map(p => p.id));

        function badgeHTML(b){
          if(b==='new') return '<span class="badge badge-new">New</span>';
          if(b==='sale') return '<span class="badge badge-sale">Sale</span>';
          return '';
        }
        function stars(r){ return '★'.repeat(Math.floor(r))+'☆'.repeat(5-Math.floor(r)); }

        function cardHTML(p, idx){
            const imagePath = p.image 
                ? (p.image.startsWith('/') || p.image.startsWith('http') ? p.image : `/img/${p.image}`) 
                : null;

            const imgHTML = imagePath 
                ? `<img src="${imagePath}" style="width:100%;height:100%;object-fit:contain;padding:16px;transition:transform .5s ease;">` 
                : `<i class='bx ${p.icon}'></i>`;

            const isWished = wished.has(p.id) ? 'wished' : '';

            return `
            <div class="product-card" style="animation-delay:${idx*0.06}s" onclick="location.href='/User/Store/Details/${p.id}'">
                <div class="card-img">
                    ${imgHTML}
                    <div class="card-badges">${badgeHTML(p.badge)}</div>
                    <button type="button" class="card-wish ${isWished}" data-id="${p.id}" onclick="handleToggleWish(event, this, ${p.id})">
                        <i class='bx ${wished.has(p.id) ? 'bxs-heart' : 'bx-heart'}'></i>
                    </button>
                </div>
                <div class="card-body">
                    <div class="card-cat">${p.cat}</div>
                    <div class="card-name">${p.name}</div>
                    <div class="card-footer">
                        <div class="card-price">
                            ${p.price.toLocaleString('vi-VN')} đ
                            ${p.oldPrice ? `<span class="old">${p.oldPrice.toLocaleString('vi-VN')} đ</span>` : ''}
                        </div>
                        <div class="card-stars">
                            ${stars(p.rating)}
                            <span>(${p.reviews})</span>
                        </div>
                    </div>
                </div>
            </div>`;
        }

        async function handleToggleWish(e, btn, id) {
            e.stopPropagation();
            
            if (typeof toggleWish === 'function') {
                // Gọi hàm toggleWish chung từ favorite.js
                await toggleWish(e, btn, id); 
                
                // Đồng bộ trạng thái vào Set wished
                if (btn.classList.contains('wished')) {
                    wished.add(id);
                } else {
                    wished.delete(id);
                }
                
                // Re-render để cập nhật tất cả các vị trí xuất hiện của sản phẩm này (nếu có)
                renderAll();
            } else {
                // Fallback nếu không load được favorite.js
                if(wished.has(id)) wished.delete(id); else wished.add(id);
                renderAll();
            }
        }

        function renderAll(){
          // Show top 8 best sellers in slider
          const bs = [...PRODUCTS].sort((a,b)=>b.reviews-a.reviews).slice(0,12);
          document.getElementById('bestSellers').innerHTML = bs.map((p,i)=>cardHTML(p,i)).join('');

          // Show top 8 new arrivals in slider
          const na = PRODUCTS.filter(p=>p.isNew).length > 0 
            ? PRODUCTS.filter(p=>p.isNew).slice(0,12)
            : [...PRODUCTS].reverse().slice(0,12);
          document.getElementById('newArrivals').innerHTML = na.map((p,i)=>cardHTML(p,i)).join('');

          // Update slider buttons visibility
          if(typeof updateSliderButtons === 'function'){
            updateSliderButtons('bestSellers');
            updateSliderButtons('newArrivals');
          }
        }

        renderAll();
    </script>
}