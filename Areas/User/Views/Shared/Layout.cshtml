
@{
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Pbao Performance</title>

    <link rel="stylesheet" href="~/Customer/assets/css/home.css">
    <link rel="stylesheet" href="~/css/Use_web/Style.css" />
    <link rel="stylesheet" href="~/css/Use_web/Notification.css" />
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- ── SEARCH OVERLAY (APPLE STYLE) ── -->
    <div id="search-overlay" class="search-overlay">
        <div class="search-container">
            <div class="search-bar">
                <i class='bx bx-search'></i>
                <input type="text" placeholder="Tìm kiếm vợt, giày, phụ kiện..." id="search-input">
                <button id="close-search"><i class='bx bx-x'></i></button>
            </div>
            <div class="search-quick-links">
                <span class="quick-label">Quick Links</span>
                <ul>
                    <li><a href="#"><i class='bx bx-right-arrow-alt'></i> Vợt cầu lông</a></li>
                    <li><a href="#"><i class='bx bx-right-arrow-alt'></i> Giày cầu lông</a></li>
                    <li><a href="#"><i class='bx bx-right-arrow-alt'></i> Phụ kiện cầu lông</a></li>
                    <li><a href="#"><i class='bx bx-right-arrow-alt'></i> Quần áo thể thao</a></li>
                </ul>
            </div>
        </div>
    </div>
    <nav>
        <div class="nav-inner">
            <a asp-area="User" asp-controller="Home" asp-action="Index" class="logo">Pbao</a>
            <div class="nav-links">
                <a asp-area="User" asp-controller="Home" asp-action="Index">Home</a>
                <a asp-area="User" asp-controller="Store" asp-action="Index">Store</a>
                
                <a href="#">Apparel</a>
                <a href="#">Footwear</a>
            </div>
            <div class="nav-actions">
                <i class='bx bx-search' id="open-search"></i>
                
                <div class="user-wrap">
                    <i class='bx bx-user' id="user-icon"></i>
                    <!-- USER DROPDOWN -->
                    <div class="user-dropdown" id="user-dropdown">
                        <div class="dropdown-section">
                            <span class="user-hello">Xin chào, <b>@User.Identity.Name</b></span>
                            <a asp-area="User" asp-controller="Account" asp-action="Index"><i class='bx bx-user-circle'></i> Tài khoản của tôi</a>
                            <a asp-area="User" asp-controller="Order" asp-action="Index"><i class='bx bx-package'></i> Đơn hàng</a>
                            <a href="#"><i class='bx bx-heart'></i> Wishlist</a>
                        </div>
                        
                        @if (User.IsInRole("Admin"))
                        {
                            <div class="dropdown-section">
                                <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="admin-link">
                                    <i class='bx bx-shield-quarter'></i> Trang Quản Trị (Admin)
                                </a>
                            </div>
                        }

                        <div class="dropdown-section">
                            <a href="#"><i class='bx bx-cog'></i> Cài đặt</a>
                            <a asp-area="User" asp-controller="Account" asp-action="Logout" class="logout-link">
                                <i class='bx bx-log-out'></i> Đăng xuất
                            </a>
                        </div>
                    </div>
                </div>

                <div class="cart-wrap">
                    <a asp-area="User" asp-controller="Cart" asp-action="Index" style="color: inherit; text-decoration: none;">
                        <i class='bx bx-shopping-bag'></i>
                    </a>
                    <div class="cart-dot"></div>
                </div>
            </div>
        </div>
    </nav>

    <style>
        /* ── SEARCH OVERLAY STYLES ── */
        .search-overlay {
            position: fixed;
            top: -100%;
            left: 0;
            width: 100%;
            height: 100vh;
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(20px);
            z-index: 1000;
            transition: top 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            justify-content: center;
            padding-top: 80px;
        }

        .search-overlay.active {
            top: 0;
        }

        .search-container {
            width: 100%;
            max-width: 680px;
            padding: 0 24px;
        }

        .search-bar {
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid var(--border);
            padding-bottom: 8px;
            margin-bottom: 24px;
        }

        .search-bar i {
            font-size: 24px;
            color: var(--muted);
        }

        .search-bar input {
            flex: 1;
            border: none;
            background: transparent;
            font-size: 24px;
            font-weight: 500;
            outline: none;
            color: var(--text);
        }

        .search-bar button {
            background: transparent;
            border: none;
            cursor: pointer;
            font-size: 28px;
            color: var(--sub);
            transition: color 0.2s;
        }

        .search-bar button:hover {
            color: var(--text);
        }

        .search-quick-links .quick-label {
            font-size: 12px;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 16px;
            display: block;
        }

        .search-quick-links ul {
            list-style: none;
            padding: 0;
        }

        .search-quick-links li {
            margin-bottom: 12px;
        }

        .search-quick-links a {
            text-decoration: none;
            color: var(--text);
            font-size: 14px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: color 0.2s, transform 0.2s;
        }

        .search-quick-links a i {
            font-size: 18px;
            color: var(--muted);
        }

        .search-quick-links a:hover {
            color: var(--accent);
            transform: translateX(5px);
        }

        /* ── USER DROPDOWN STYLES ── */
        .user-wrap {
            position: relative;
        }

        .user-dropdown {
            position: absolute;
            top: calc(100% + 15px);
            right: -10px;
            width: 240px;
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.08);
            border: 1px solid rgba(0,0,0,0.05);
            padding: 8px 0;
            opacity: 0;
            visibility: hidden;
            transform: translateY(10px);
            transition: all 0.3s ease;
            z-index: 300;
        }

        .user-dropdown::before {
            content: '';
            position: absolute;
            top: -6px;
            right: 14px;
            width: 12px;
            height: 12px;
            background: #fff;
            transform: rotate(45deg);
            border-top: 1px solid rgba(0,0,0,0.05);
            border-left: 1px solid rgba(0,0,0,0.05);
        }

        .user-dropdown.active {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .dropdown-section {
            padding: 8px 0;
        }

        .dropdown-section:not(:last-child) {
            border-bottom: 1px solid #f0f0f2;
        }

        .user-hello {
            display: block;
            padding: 8px 20px;
            font-size: 13px;
            color: var(--sub);
            margin-bottom: 4px;
        }

        .user-dropdown a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 20px;
            text-decoration: none;
            color: var(--text);
            font-size: 13px;
            transition: background 0.2s;
        }

        .user-dropdown a i {
            font-size: 18px;
            color: var(--sub);
        }

        .user-dropdown a:hover {
            background: #f5f5f7;
        }

        .admin-link {
            color: var(--accent) !important;
            font-weight: 600;
        }

        .logout-link {
            color: var(--new) !important;
        }

        /* ── NOTIFICATION STYLES ── */
        #cart-notification {
            position: fixed;
            top: 80px;
            right: 20px;
            background: var(--text);
            color: #fff;
            padding: 16px 24px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            gap: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            z-index: 9999;
            transform: translateX(120%);
            transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        #cart-notification.show {
            transform: translateX(0);
        }
    </style>

    <div id="toast-container"></div>

    <!-- Existing Cart Notification (Keep for compatibility) -->
    <div id="cart-notification">
        <i class='bx bx-check-circle' style="font-size: 24px; color: #10b981;"></i>
        <span id="notif-message">Đã thêm vào giỏ hàng!</span>
    </div>

    @using System.Text.Json
    @if (TempData["Notification"] != null)
    {
        var notifyData = JsonSerializer.Deserialize<dynamic>(TempData["Notification"].ToString());
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const data = @Html.Raw(TempData["Notification"]);
                showToast(data.Message, data.Type, data.ShowLoginLink);
            });
        </script>
    }

    <script>
        function showToast(message, type = 'success', showLogin = false) {
            const container = document.getElementById('toast-container');
            if (!container) return;

            const toast = document.createElement('div');
            toast.className = `toast-item ${type}`;

            let icon = 'bx-check-circle';
            if (type === 'error') icon = 'bx-x-circle';
            if (type === 'warning') icon = 'bx-error-circle';

            let html = `
                <div class="toast-content">
                    <i class='bx ${icon} toast-icon'></i>
                    <span class="toast-message">${message}</span>
                </div>
            `;

            if (showLogin) {
                html += `<a href="/Account/Login" class="toast-login-btn">Đăng nhập</a>`;
            }

            html += `<span class="toast-close" onclick="this.parentElement.classList.add('hide'); setTimeout(() => this.parentElement.remove(), 400)">×</span>`;

            toast.innerHTML = html;
            container.appendChild(toast);

            // Auto-hide after 5 seconds
            setTimeout(() => {
                if (toast.parentElement) {
                    toast.classList.add('hide');
                    setTimeout(() => toast.remove(), 400);
                }
            }, 5000);
        }

        document.addEventListener('DOMContentLoaded', function() {
            // --- Search Logic ---
            const openSearch = document.getElementById('open-search');
            const closeSearch = document.getElementById('close-search');
            const searchOverlay = document.getElementById('search-overlay');
            const searchInput = document.getElementById('search-input');

            if (openSearch) {
                openSearch.addEventListener('click', () => {
                    searchOverlay.classList.add('active');
                    setTimeout(() => searchInput.focus(), 400);
                    document.body.style.overflow = 'hidden'; // Prevent scroll
                });
            }

            if (closeSearch) {
                closeSearch.addEventListener('click', () => {
                    searchOverlay.classList.remove('active');
                    document.body.style.overflow = '';
                });
            }

            // --- User Dropdown Logic ---
            const userIcon = document.getElementById('user-icon');
            const userDropdown = document.getElementById('user-dropdown');

            if (userIcon) {
                userIcon.addEventListener('click', (e) => {
                    e.stopPropagation();
                    userDropdown.classList.toggle('active');
                });
            }

            document.addEventListener('click', (e) => {
                if (userDropdown && !userDropdown.contains(e.target) && e.target !== userIcon) {
                    userDropdown.classList.remove('active');
                }
            });

            // Close search on Escape key
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') {
                    if (searchOverlay) searchOverlay.classList.remove('active');
                    if (userDropdown) userDropdown.classList.remove('active');
                    document.body.style.overflow = '';
                }
            });
        });

        // Global notification function
        function showNotification(message) {
            const notif = document.getElementById('cart-notification');
            const msg = document.getElementById('notif-message');
            if (notif && msg) {
                msg.innerText = message;
                notif.classList.add('show');
                setTimeout(() => {
                    notif.classList.remove('show');
                }, 3000);
            }
        }
    </script>

    
        @RenderBody()   
   

    <footer>
        <div class="footer-inner">
            <div class="footer-cols">
                <div>
                    <h4>Shop</h4>
                    <ul>
                        <li><a href="#">Rackets</a></li>
                        <li><a href="#">Shuttlecocks</a></li>
                        <li><a href="#">Apparel</a></li>
                        <li><a href="#">Footwear</a></li>
                        <li><a href="#">Bags</a></li>
                        <li><a href="#">Accessories</a></li>
                    </ul>
                </div>
                <div>
                    <h4>Brands</h4>
                    <ul>
                        <li><a href="#">Yonex</a></li>
                        <li><a href="#">Victor</a></li>
                        <li><a href="#">Li-Ning</a></li>
                        <li><a href="#">Pbao Series</a></li>
                    </ul>
                </div>
                <div>
                    <h4>Account</h4>
                    <ul>
                        <li><a asp-area="" asp-controller="Account" asp-action="Login">Sign In</a></li>
                        <li><a href="#">Orders</a></li>
                        <li><a href="#">Wishlist</a></li>
                        <li><a href="#">Store Credit</a></li>
                    </ul>
                </div>
                <div>
                    <h4>About Pbao</h4>
                    <ul>
                        <li><a href="#">Our Story</a></li>
                        <li><a href="#">Newsroom</a></li>
                        <li><a href="#">Careers</a></li>
                        <li><a href="#">Contact</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <span>Copyright © 2026 Pbao Inc. All rights reserved.</span>
                <div>
                    <a href="#">Privacy</a>
                    <a href="#">Terms</a>
                    <a href="#">Sales Policy</a>
                </div>
            </div>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>