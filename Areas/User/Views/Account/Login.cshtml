@model Getdata1.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Trang chủ";
    Layout = "~/Areas/User/Views/Shared/Layout.cshtml";
}
@* no se auto render vao day *@
@section Styles
{
    <link href="~/css/Use_web/Login/login.css" rel="stylesheet" />
}

<!-- LOGIN / SIGNUP SECTION -->
<section class="auth-section">

    <!-- LEFT -->
    <div class="auth-left">
        <span class="auth-label">Pbao Account</span>

        <h1>
            Elevate your <br>
            badminton journey.
        </h1>

        <p>
            Access orders, wishlist, exclusive drops and
            premium badminton essentials in one place.
        </p>

        <div class="auth-benefits">
            <div>Fast checkout experience</div>
            <div>Track your orders instantly</div>
            <div>Member-only product releases</div>
        </div>
    </div>

    <!-- RIGHT -->
    <div class="auth-card">

        <div class="auth-tabs">
            <a asp-area="User" asp-controller="Account" asp-action="Login" class="active">Sign In</a>
            <a asp-area="User" asp-controller="Account"  asp-action="Register">Create Account</a>
            @* <button class="active">Sign In</button>
            <button>Create Account</button> *@

        </div>

      <form asp-area="User" asp-controller="Account" asp-action="Login" method="post">
    @Html.AntiForgeryToken()
    @* under code is accept ModelStade *@
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="input-group">
        <label>Email Address</label>
        <input asp-for="Email" type="email" placeholder="name@example.com" class="form-control">
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="input-group">
        <label>Password</label>
        <input asp-for="Password" type="password" placeholder="••••••••" class="form-control">
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>

    <div class="auth-row">
        <label class="remember">
            <input asp-for="RememberMe" type="checkbox">
            Remember me
        </label>
        <a href="#">Forgot password?</a>
    </div>

    <button type="submit" class="auth-btn">
        Continue
    </button>

    <div class="auth-divider">
        <span>or</span>
    </div>

    <button type="button" class="social-btn">
        Continue with Google
    </button>

    <p class="auth-note">
        By continuing, you agree to our Terms and Privacy Policy.
    </p>

</form>
    </div>

</section>
