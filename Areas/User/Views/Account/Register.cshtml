@model Getdata1.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Trang chủ";
    Layout = "~/Areas/User/Views/Shared/Layout.cshtml";
}
@* no se auto render vao day *@
@section Styles
{
    <link href="~/css/Use_web/Login/login.css" rel="stylesheet" />
}

<!-- LOGIN / SIGNUP SECTION -->
<section class="auth-section">

    <!-- LEFT -->
    <div class="auth-left">
        <span class="auth-label">Pbao Account</span>

        <h1>
            Elevate your <br>
            badminton journey.
        </h1>

        <p>
            Access orders, wishlist, exclusive drops and
            premium badminton essentials in one place.
        </p>

        <div class="auth-benefits">
            <div>Fast checkout experience</div>
            <div>Track your orders instantly</div>
            <div>Member-only product releases</div>
        </div>
    </div>

    <!-- RIGHT -->
    <div class="auth-card">

        <div class="auth-tabs">
            @* <button class="active">Sign In</button>
            <button>Create Account</button> *@
            <a asp-area="User" asp-controller="Account" asp-action="Login">Sign In</a>
            <a asp-area="User" asp-controller="Account" asp-action="Register" class="active">Create Account</a> <!-- Chữ active nằm ở đây nè -->
        </div>

        <form asp-area="User" asp-controller="Account" asp-action="Register" method="POST">
            @Html.AntiForgeryToken()

       

            <div class="input-group">
                <label>Email Address</label>
                <input type="email" asp-for="Email" placeholder="name@example.com">
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

        

            <div class="input-group">
                <label>Password</label>
                <input type="password" asp-for="Password" placeholder="••••••••">
            </div>

            <div class="input-group">
                <label>Confirm Password</label>
                <input type="password" asp-for="ConfirmPassword" placeholder="••••••••">
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="auth-row" style="justify-content: flex-start;">
                <label class="remember">
                    <input type="checkbox" name="AgreeTerms">
                    I agree to Terms & Privacy Policy
                </label>
            </div>

            <button type="submit" class="auth-btn">Create Account</button>

            <div class="auth-divider"><span>or</span></div>

            <button type="button" class="social-btn">Sign up with Google</button>

            <p class="auth-note">
                Already have an account?
                <a asp-area="User" asp-controller="Account" asp-action="Login" style="color:var(--accent); text-decoration:none; font-weight:600;">Sign in here</a>
            </p>

        </form>

       
    </div>

</section>

