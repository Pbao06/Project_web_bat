@model IEnumerable<Getdata1.DTOs.OrderDto>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
    Layout = "~/Areas/User/Views/Shared/Layout.cshtml";
}

<style>
    .orders-container {
        max-width: 1100px;
        margin: 60px auto;
        padding: 0 24px;
        font-family: 'DM Sans', sans-serif;
    }

    .orders-header {
        margin-bottom: 40px;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
    }

    .orders-header h1 {
        font-family: 'Syne', sans-serif;
        font-size: 36px;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .orders-header p {
        color: #666;
        font-size: 16px;
    }

    .order-card {
        background: #fff;
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 24px;
        border: 1px solid #f0f0f2;
        transition: all 0.3s ease;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .order-card:hover {
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        transform: translateY(-2px);
    }

    .order-info {
        display: flex;
        gap: 40px;
    }

    .info-group label {
        display: block;
        font-size: 12px;
        color: #999;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 6px;
    }

    .info-group span {
        font-weight: 600;
        font-size: 15px;
        color: #1a1a1a;
    }

    .order-status {
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .status-pending { background: #fff8e6; color: #b28900; }
    .status-paid { background: #f0fdf4; color: #166534; }
    .status-processing { background: #e6f3ff; color: #007bff; }
    .status-shipped { background: #f8fafc; color: #475569; }
    .status-delivered { background: #f0fdf4; color: #166534; }
    .status-cancelled { background: #fff1f0; color: #cf1322; }

    .order-actions .btn-details {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: #1a1a1a;
        color: #fff;
        text-decoration: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
        transition: background 0.2s;
    }

    .order-actions .btn-details:hover {
        background: #333;
    }

    .empty-orders {
        text-align: center;
        padding: 100px 0;
    }

    .empty-orders i {
        font-size: 64px;
        color: #e0e0e0;
        margin-bottom: 24px;
    }

    .empty-orders h2 {
        font-family: 'Syne', sans-serif;
        font-size: 24px;
        margin-bottom: 12px;
    }

    .btn-shop {
        display: inline-block;
        margin-top: 20px;
        padding: 12px 30px;
        background: #1a1a1a;
        color: #fff;
        text-decoration: none;
        border-radius: 30px;
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .order-card {
            flex-direction: column;
            align-items: flex-start;
            gap: 20px;
        }
        .order-info {
            flex-wrap: wrap;
            gap: 20px;
        }
        .order-actions {
            width: 100%;
        }
        .order-actions .btn-details {
            justify-content: center;
        }
    }
</style>

<div class="orders-container">
    <div class="orders-header">
        <div>
            <h1>Đơn hàng của tôi</h1>
            <p>Theo dõi và quản lý các đơn hàng bạn đã đặt.</p>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        @foreach (var order in Model)
        {
            <div class="order-card">
                <div class="order-info">
                    <div class="info-group">
                        <label>Mã đơn hàng</label>
                        <span>#PBAO-@order.Id</span>
                    </div>
                    <div class="info-group">
                        <label>Ngày đặt</label>
                        <span>@order.OrderDate.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="info-group">
                        <label>Tổng cộng</label>
                        <span>$@order.TotalPrice.ToString("N2")</span>
                    </div>
                    <div class="info-group">
                        <label>Trạng thái</label>
                        <span class="order-status status-@order.Status.ToString().ToLower()">
                            @order.Status
                        </span>
                    </div>
                </div>
                <div class="order-actions">
                    <a asp-area="User" asp-controller="Order" asp-action="Details" asp-route-id="@order.Id" class="btn-details">
                        Chi tiết đơn hàng <i class='bx bx-right-arrow-alt'></i>
                    </a>
                </div>
            </div>
        }
    }
    else
    {
        <div class="empty-orders">
            <i class='bx bx-package'></i>
            <h2>Bạn chưa có đơn hàng nào</h2>
            <p>Có vẻ bạn chưa mua sắm gì tại Pbao. Khám phá ngay nhé!</p>
            <a asp-area="User" asp-controller="Store" asp-action="Index" class="btn-shop">Bắt đầu mua sắm</a>
        </div>
    }
</div>
