
@model Getdata1.DTOs.CartDto

@{
    ViewData["Title"] = "Shopping Cart";
    Layout = "~/Areas/User/Views/Shared/_CheckOutLayout.cshtml";
    ViewBag.Step = 1;
}

@section Styles {
    <link href="~/css/Use_web/Cart/cart.css" rel="stylesheet" />
}

<div class="page">

    <div class="page-heading">
        <div class="page-heading-left">
            <h1>Giỏ hàng <span id="headCount" style="color:var(--muted);font-weight:400;font-size:28px">(0)</span></h1>
            <p id="headSub">Bạn có <strong>0 sản phẩm</strong> trong giỏ hàng.</p>
        </div>
        <button class="btn-clear" onclick="clearAll()">
            <i class='bx bx-trash'></i> Xoá tất cả
        </button>
    </div>

    <div class="cart-grid">

        <!-- ── LEFT: ITEMS ── -->
        <div>
            <div class="cart-table-head">
                <div class="col-product">Sản phẩm</div>
                <div class="col-price">Đơn giá</div>
                <div class="col-qty">Số lượng</div>
                <div class="col-del"></div>
            </div>

            <div class="cart-items" id="cartItems">
                <!-- Rendered by JS -->
            </div>

            <!-- Empty state -->
            <div class="cart-empty" id="cartEmpty">
                <div class="empty-icon"><i class='bx bx-shopping-bag'></i></div>
                <h3>Giỏ hàng trống</h3>
                <p>Có vẻ bạn chưa thêm sản phẩm nào. Khám phá bộ sưu tập mới nhất của Pbao nhé!</p>
                <button class="btn-shop-now" onclick="addBack()">
                    <i class='bx bx-store'></i> Khám phá sản phẩm
                </button>
            </div>

            <!-- You may also like -->
            <div class="also-like" id="alsoLike">
                <span class="section-label">Gợi ý cho bạn</span>
                <div class="also-like-head">
                    <h2>Có thể bạn thích</h2>
                    <a href="/User/Store">Xem tất cả <i class='bx bx-right-arrow-alt'></i></a>
                </div>
                <div class="suggest-strip" id="suggestStrip"></div> 
                @* render -> sản phẩm goi y  *@
            </div>
        </div>

        <!-- ── RIGHT: SUMMARY ── -->
        <div class="order-summary">
            <div class="os-header">
                <h3>Tóm tắt đơn hàng</h3>
            </div>

            <!-- Promo -->
            <div class="promo-row">
                <div class="promo-inner">
                    <input class="promo-input" type="text" placeholder="Mã giảm giá..." id="promoInput">
                    <button class="btn-promo" onclick="applyPromo()">Áp dụng</button>
                </div>
                <div class="promo-success" id="promoSuccess">
                    <i class='bx bx-check-circle'></i>
                    Mã <strong>PBAO2026</strong> — Giảm 23.000 đ!
                </div>
                <div class="promo-err" id="promoErr">Mã không hợp lệ. Thử lại nhé!</div>
            </div>

            <!-- Totals -->
            <div class="os-totals">
                <div class="os-row">
                    <span>Tạm tính</span>
                    <span class="val" id="subTotal">0 đ</span>
                </div>
                <div class="os-row discount" id="discountRow" style="display:none">
                    <span>Giảm giá (PBAO2026)</span>
                    <span class="val">-0 đ</span>
                </div>
                <div class="os-row shipping">
                    <span>Vận chuyển</span>
                    <span class="val">Miễn phí</span>
                </div>
                <div class="free-ship-notice" id="freeShipNotice">
                    <i class='bx bx-check-shield'></i>
                    <div>
                        Đơn hàng của bạn đủ điều kiện giao hàng miễn phí!
                        <div class="ship-progress-bar" style="margin-top:6px">
                            <div class="ship-progress-fill" id="shipFill" style="width:100%"></div>
                        </div>
                    </div>
                </div>
                <div class="os-row total">
                    <span>Tổng cộng</span>
                    <span class="val" id="totalVal">0 đ</span>
                </div>
            </div>

            <!-- CTA -->
            <div class="os-cta">
                <button class="btn-checkout">
                    <i class='bx bx-lock-alt'></i>
                    Tiến hành thanh toán
                </button>
                <button class="btn-continue">
                    <i class='bx bx-left-arrow-alt'></i>
                    Tiếp tục mua sắm 
                </button>
                <div class="os-secure">
                    <i class='bx bx-shield-quarter'></i>
                    Bảo mật 256-bit SSL · Thanh toán an toàn
                </div>
            </div>

            <div class="pay-logos">
                <div class="pay-logo-pill">VISA</div>
                <div class="pay-logo-pill">MC</div>
                <div class="pay-logo-pill">JCB</div>
                <div class="pay-logo-pill">MOMO</div>
                <div class="pay-logo-pill">COD</div>
            </div>
        </div>

    </div>
</div>

<script>
    /* ── DATA & INITIALIZATION ── */
    let currentCart = null;

    async function loadCart() {
        try {
            const response = await fetch('/User/Cart/GetCart');
            const data = await response.json();
            currentCart = data;
            render(data);
        } catch (error) {
            console.error('Error loading cart:', error);
        }
    }

    /* ── RENDER ── */
    function render(data) {
        if (!data) return;

        const container = document.getElementById('cartItems');
        const empty     = document.getElementById('cartEmpty');
        const heading   = document.getElementById('headCount');
        const headSub   = document.getElementById('headSub');
        const tableHead = document.querySelector('.cart-table-head');
        
        const items = data.items || []; 
        const itemCount = data.totalItems || 0;

        heading.textContent = `(${itemCount})`;
        headSub.innerHTML = items.length
            ? `Bạn có <strong>${itemCount} sản phẩm</strong> trong giỏ hàng.`
            : `Giỏ hàng của bạn đang trống.`;

        if (items.length === 0) {
            container.innerHTML = ''; 
            empty.classList.add('show'); 
            if(tableHead) tableHead.style.display = 'none';
            document.getElementById('alsoLike').style.opacity = '.5'; 
        } else {
            empty.classList.remove('show');
            if(tableHead) tableHead.style.display = 'grid';
            document.getElementById('alsoLike').style.opacity = '1'; 
            container.innerHTML = items.map((item, idx) => itemHTML(item, idx)).join(''); 
        }

        // Totals
        document.getElementById('subTotal').textContent = (data.subTotal || 0).toLocaleString('vi-VN') + ' đ';
        
        const hasPromo = data.appliedPromoCode != null;
        document.getElementById('discountRow').style.display = hasPromo ? 'flex' : 'none';
        if (hasPromo) {
            document.getElementById('discountRow').querySelector('span:first-child').textContent = `Giảm giá (${data.appliedPromoCode})`;
            document.getElementById('discountRow').querySelector('.val').textContent = '-' + (data.discountAmount || 0).toLocaleString('vi-VN') + ' đ';
            document.getElementById('promoSuccess').classList.add('show');
            document.getElementById('promoSuccess').innerHTML = `<i class='bx bx-check-circle'></i> Mã <strong>${data.appliedPromoCode}</strong> — Giảm ${(data.discountAmount || 0).toLocaleString('vi-VN')} đ!`;
        } else {
            document.getElementById('promoSuccess').classList.remove('show');
        }

        document.getElementById('totalVal').textContent = (data.totalPrice || 0).toLocaleString('vi-VN') + ' đ';

        // Shipping bar
        const sub = data.subTotal || 0;
        const threshold = 2000000;
        const pct = Math.min((sub / threshold) * 100, 100);
        const shipFill = document.getElementById('shipFill');
        if(shipFill) shipFill.style.width = pct + '%';
        
        const noticeDiv = document.getElementById('freeShipNotice').querySelector('div');
        if (sub >= threshold) {
            noticeDiv.innerHTML =
                'Đơn hàng của bạn đủ điều kiện giao hàng <strong>miễn phí</strong>!<div class="ship-progress-bar" style="margin-top:6px"><div class="ship-progress-fill" id="shipFill" style="width:100%"></div></div>';
        } else {
            const need = (threshold - sub).toLocaleString('vi-VN');
            noticeDiv.innerHTML =
                `Mua thêm <strong>${need} đ</strong> để được <strong>miễn phí vận chuyển</strong>!<div class="ship-progress-bar" style="margin-top:6px"><div class="ship-progress-fill" id="shipFill" style="width:${pct}%"></div></div>`;
        }
    }

    function itemHTML(item, idx) {
        const imgPath = item.image ? (item.image.startsWith('/') ? item.image : `/img/${item.image}`) : '/img/no-img.jfif';
        
        return `
        <div class="cart-item" id="item-${item.productId}" style="animation-delay:${idx*0.06}s">
            <div class="item-product">
                <div class="item-thumb">
                    <img src="${imgPath}" alt="${item.productName}" />
                </div>
                <div class="item-meta">
                    <div class="item-cat">${item.categoryName || 'Sản phẩm'}</div>
                    <div class="item-name">${item.productName}</div>
                    <div class="item-variant">
                        <span class="item-variant-pill">${item.variantInfo || 'Tiêu chuẩn'}</span>
                    </div>
                </div>
            </div>
            <div class="item-price">${item.price.toLocaleString('vi-VN')} đ</div>
            <div class="item-qty-wrap">
                <div class="qty-ctrl">
                    <button class="qty-btn" onclick="changeQty(${item.productId}, -1)"><i class='bx bx-minus'></i></button>
                    <span class="qty-num">${item.quantity}</span>
                    <button class="qty-btn" onclick="changeQty(${item.productId}, 1)"><i class='bx bx-plus'></i></button>
                </div>
            </div>
            <div class="item-del">
                <button class="btn-del" onclick="removeItem(${item.productId}, '${item.productName}')" title="Xoá">
                    <i class='bx bx-x'></i>
                </button>
            </div>
        </div>`;
    }

    /* ── ACTIONS ── */
    async function changeQty(productId, delta) {
        if (!currentCart) return;
        const item = currentCart.items.find(i => i.productId === productId);
        if (!item) return;
        
        const newQty = item.quantity + delta;
        if (newQty <= 0) {
            removeItem(productId, item.productName);
            return;
        }

        try {
            const response = await fetch(`/User/Cart/UpdateQuantity?productId=${productId}&quantity=${newQty}`, {
                method: 'POST'
            });
            const result = await response.json();
            if (result.success) {
                currentCart = result.cart;
                render(result.cart);
                
                const el = document.querySelector(`#item-${productId} .qty-num`);
                if (el) { el.style.transform='scale(1.4)'; setTimeout(()=>el.style.transform='',200); }
            }
        } catch (error) {
            console.error('Error updating quantity:', error);
        }
    }

    async function removeItem(productId, productName) {
        showGlobalModal({
            title: 'Xác nhận xoá',
            content: `Bạn có chắc chắn muốn xoá <strong>${productName}</strong> khỏi giỏ hàng?`,
            confirmText: 'Xoá ngay',
            cancelText: 'Hủy',
            onConfirm: async function() {
                const el = document.getElementById('item-' + productId);
                if (el) {
                    el.classList.add('removing');
                    
                    try {
                        const response = await fetch(`/User/Cart/RemoveFromCart?productId=${productId}`, {
                            method: 'POST'
                        });
                        const result = await response.json();
                        if (result.success) {
                            setTimeout(() => {
                                currentCart = result.cart;
                                render(result.cart);
                                showToast('Đã xoá sản phẩm khỏi giỏ hàng.', 'success');
                            }, 350);
                        }
                    } catch (error) {
                        console.error('Error removing item:', error);
                        showToast('Có lỗi xảy ra khi xoá sản phẩm.', 'error');
                    }
                }
            }
        });
    }

    async function clearAll() {
        if (!currentCart || currentCart.items.length === 0) return;
        
        showGlobalModal({
            title: 'Xoá toàn bộ giỏ hàng',
            content: 'Bạn có chắc chắn muốn xoá tất cả sản phẩm trong giỏ hàng không?',
            confirmText: 'Xoá tất cả',
            cancelText: 'Hủy',
            onConfirm: async function() {
                const items = document.querySelectorAll('.cart-item');
                items.forEach((el, i) => {
                    setTimeout(() => {
                        el.style.transition = '.25s'; el.style.opacity='0'; el.style.transform='translateX(20px)';
                    }, i * 60);
                });

                try {
                    const response = await fetch('/User/Cart/ClearCart', { method: 'POST' });
                    const result = await response.json();
                    if (result.success) {
                        setTimeout(() => {
                            currentCart = { items: [], totalItems: 0, subTotal: 0, totalPrice: 0, discountAmount: 0 };
                            render(currentCart);
                            showToast('Đã làm trống giỏ hàng.', 'success');
                        }, items.length * 60 + 300);
                    }
                } catch (error) {
                    console.error('Error clearing cart:', error);
                    showToast('Có lỗi xảy ra khi xoá giỏ hàng.', 'error');
                }
            }
        });
    }

    async function applyPromo() {
        const val = document.getElementById('promoInput').value.trim();
        if (!val) return;

        const successEl = document.getElementById('promoSuccess');
        const errEl     = document.getElementById('promoErr');
        successEl.classList.remove('show');
        errEl.classList.remove('show');

        try {
            const response = await fetch(`/User/Cart/ApplyPromo?promoCode=${encodeURIComponent(val)}`, {
                method: 'POST'
            });
            const result = await response.json();
            
            if (result.success) {
                currentCart = result.cart;
                render(result.cart);
            } else {
                errEl.textContent = result.message;
                errEl.classList.add('show');
                document.getElementById('promoInput').style.borderColor = 'var(--err)';
                setTimeout(() => document.getElementById('promoInput').style.borderColor = '', 1200);
            }
        } catch (error) {
            console.error('Error applying promo:', error);
        }
    }

    /* ── SUGGESTIONS ── */
    async function renderSuggest() {
        const strip = document.getElementById('suggestStrip');
        if (!strip) return;

        try {
            const response = await fetch('/User/Cart/GetSuggestedProducts');
            const products = await response.json();
            
            if (!products || products.length === 0) {
                document.getElementById('alsoLike').style.display = 'none';
                return;
            }

            const displayProducts = products.slice(0, 4);

            strip.innerHTML = displayProducts.map(s => {
                const imgPath = s.image ? (s.image.startsWith('/') ? s.image : `/img/${s.image}`) : '/img/no-img.jfif';
                return `
                <div class="suggest-card" onclick="location.href='/User/Store/Details/${s.id}'" style="cursor:pointer;">
                    <div class="suggest-img">
                         <img src="${imgPath}" alt="${s.name}" style="width:100%; height:100%; object-fit:contain; padding:12px;" />
                    </div>
                    <div class="suggest-body">
                        <div class="suggest-cat">${s.categoryName || 'Sản phẩm'}</div>
                        <div class="suggest-name">${s.name}</div>
                        <div class="suggest-footer">
                            <span class="suggest-price">${s.price.toLocaleString('vi-VN')} đ</span>
                           
                        </div>
                    </div>
                </div>
            `}).join('');
        } catch (error) {
            console.error('Error loading suggestions:', error);
            document.getElementById('alsoLike').style.display = 'none';
        }
    }

    async function addToCart(productId) {
        try {
            const response = await fetch(`/User/Cart/AddToCart?productId=${productId}&quantity=1`, {
                method: 'POST'
            });
            const result = await response.json();
            if (result.success) {
                currentCart = result.cart;
                render(result.cart);
                
                const h = document.getElementById('headCount');
                h.style.color = 'var(--success)';
                setTimeout(() => h.style.color = 'var(--muted)', 600);
            } else {
                showToast(result.message, 'error');
            }
        } catch (error) {
            console.error('Error adding to cart:', error);
            showToast('Có lỗi xảy ra khi thêm vào giỏ hàng.', 'error');
        }
    }

    function addBack() {
        window.location.href = '/User/Store';
    }

    /* Initialization */
    document.addEventListener('DOMContentLoaded', () => {
        loadCart();
        renderSuggest();
        
        const isAuthenticated = @User.Identity!.IsAuthenticated.ToString().ToLower();

        document.getElementById('promoInput').addEventListener('keydown', e => {
            if (e.key === 'Enter') applyPromo();
        });

        const btnCheckout = document.querySelector('.btn-checkout');
        if (btnCheckout) {
            btnCheckout.onclick = function() {
                if (!currentCart || (currentCart.items && currentCart.items.length === 0)) {
                    showToast('Bạn không có sản phẩm nào để thanh toán', 'warning');
                    return;
                }

                if (!isAuthenticated) {
                    showGlobalModal({
                        title: 'Yêu cầu đăng nhập',
                        content: 'Bạn cần đăng nhập để tiếp tục thanh toán. Việc này giúp chúng tôi quản lý đơn hàng của bạn tốt hơn.',
                        confirmText: 'Đi đến Đăng nhập',
                        cancelText: 'Hủy',
                        onConfirm: function() {
                            window.location.href = '/Account/Login?ReturnUrl=/User/Cart';
                        }
                    });
                    return;
                }

                window.location.href = '/User/Cart/Payment';
            };
        }

        const btnContinue = document.querySelector('.btn-continue');
        if (btnContinue) {
            btnContinue.onclick = function() {
                window.location.href = '/User/Store';
            };
        }
    });
</script>