@model Getdata1.DTOs.ProductDto
@{
    ViewData["Title"] = Model.Name + " - Details";
    var relatedProducts = ViewBag.RelatedProducts as IEnumerable<Getdata1.DTOs.ProductDto> ?? new List<Getdata1.DTOs.ProductDto>();
}
@section Styles
{
    <link href="~/css/Use_web/Store/Detail.css" rel="stylesheet" />
    <style>
        /* Gallery Fix */
        .thumb.active {
            border-color: var(--text);
            opacity: 1;
        }
        .thumb {
            opacity: 0.7;
        }

        /* Reviews Slider Styles */
        .reviews-slider {
            display: flex;
            overflow-x: auto;
            gap: 16px;
            padding: 10px 4px 20px;
            scroll-behavior: smooth;
            scrollbar-width: none;
            -ms-overflow-style: none;
        }
        .reviews-slider::-webkit-scrollbar {
            display: none;
        }
        .reviews-slider .review-card {
            flex: 0 0 320px;
            padding: 24px;
            background: var(--bg2);
            border-radius: 16px;
            border-bottom: none;
        }
        @@media (max-width: 480px) {
            .reviews-slider .review-card { flex: 0 0 280px; }
        }

        /* Related Slider Fix */
        .related-slider {
            display: flex;
            overflow-x: auto;
            gap: 16px;
            padding: 10px 4px 20px;
            scroll-behavior: smooth;
            scrollbar-width: none;
            -ms-overflow-style: none;
        }
        .related-slider::-webkit-scrollbar {
            display: none;
        }
        .related-card {
            flex: 0 0 260px;
        }
    </style>
}

<!-- BREADCRUMB -->
<div class="breadcrumb">
    <a asp-action="Index">Store</a>
    <i class='bx bx-chevron-right'></i>
    <a href="#">@Model.CategoryName</a>
    <i class='bx bx-chevron-right'></i>
    <span>@Model.Name</span>
</div>

<!-- PRODUCT LAYOUT -->
<div class="product-layout">

    <!-- GALLERY -->
    <div class="gallery">
        <div class="gallery-main" id="galleryMain">
            @if (!string.IsNullOrEmpty(Model.Image))
            {
                var mainImagePath = Model.Image.StartsWith("/") || Model.Image.StartsWith("http") ? Model.Image : (Model.Image.StartsWith("~") ? Model.Image : "~/img/" + Model.Image);
                <img src="@Url.Content(mainImagePath)" alt="@Model.Name" id="currentMainImg" style="width: 100%; height: 100%; object-fit: contain;" />
            }
            else
            {
                <i class='bx bx-baseball gallery-main-icon' id="mainIcon"></i>
            }
            <div class="gallery-badge">New</div>
            <button class="gallery-wish @(Model.IsLiked ? "wished" : "")" data-id="@Model.Id" onclick="toggleWish(event, this)">
                <i class='bx @(Model.IsLiked ? "bxs-heart" : "bx-heart")'></i>
            </button>
        </div>
        <div class="gallery-thumbs">
            @if (Model.GalleryImages != null && Model.GalleryImages.Any())
            {
                @foreach (var img in Model.GalleryImages)
                {
                    var thumbPath = img.StartsWith("/") || img.StartsWith("http") ? img : (img.StartsWith("~") ? img : "~/img/" + img);
                    <div class="thumb" onclick="changeMainImage(this, '@Url.Content(thumbPath)')">
                        <img src="@Url.Content(thumbPath)" alt="Thumbnail" style="width: 100%; height: 100%; object-fit: cover;" />
                    </div>
                }
            }
            else if (!string.IsNullOrEmpty(Model.Image))
            {
                var mainPath = Model.Image.StartsWith("/") || Model.Image.StartsWith("http") ? Model.Image : (Model.Image.StartsWith("~") ? Model.Image : "~/img/" + Model.Image);
                <div class="thumb active" onclick="changeMainImage(this, '@Url.Content(mainPath)')">
                    <img src="@Url.Content(mainPath)" alt="Thumbnail" style="width: 100%; height: 100%; object-fit: cover;" />
                </div>
            }
            else
            {
                <div class="thumb active" onclick="selectThumb(this,'bx-baseball')"><i class='bx bx-baseball'></i></div>
            }
        </div>
    </div>

    <!-- PRODUCT INFO -->
    <div class="product-info">
        <p class="info-brand">@Model.Brand</p>
        <h1 class="info-name">@Model.Name</h1>
        <div class="info-rating">
            <span class="stars">
                @for (int i = 1; i <= 5; i++)
                {
                    @(i <= Math.Round(Model.AverageRating) ? "★" : "☆")
                }
            </span>
            <span class="rating-val">@Model.AverageRating.ToString("F1")</span>
            <a class="reviews-link" onclick="switchTab('reviews')">(@Model.ReviewCount đánh giá)</a>
        </div>

        <div class="info-price">
            <span class="price-current">@Model.Price.ToString("N0") đ</span>
        </div>
        <p class="info-tax">Đã bao gồm thuế. Miễn phí vận chuyển đơn từ 1.500.000 đ.</p>

        <div class="divider"></div>

        <!-- Selectable Specs -->
        <div id="variant-selectors">
            @if (!string.IsNullOrEmpty(Model.Color))
            {
                var colors = Model.Color.Split(',').Select(s => s.Trim()).ToList();
                <div class="spec-group">
                    <p class="spec-label">Màu sắc:</p>
                    <div class="spec-pills" data-attribute="Color">
                        @foreach (var color in colors)
                        {
                            <div class="spec-pill @(colors.First() == color ? "active" : "")" onclick="selectOption(this, 'Color')">@color</div>
                        }
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.Stiffness))
            {
                var options = Model.Stiffness.Split(',').Select(s => s.Trim()).ToList();
                <div class="spec-group">
                    <p class="spec-label">Độ cứng cán:</p>
                    <div class="spec-pills" data-attribute="Stiffness">
                        @foreach (var opt in options)
                        {
                            <div class="spec-pill @(options.First() == opt ? "active" : "")" onclick="selectOption(this, 'Stiffness')">@opt</div>
                        }
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.Weight))
            {
                var options = Model.Weight.Split(',').Select(s => s.Trim()).ToList();
                <div class="spec-group">
                    <p class="spec-label">Trọng lượng:</p>
                    <div class="spec-pills" data-attribute="Weight">
                        @foreach (var opt in options)
                        {
                            <div class="spec-pill @(options.First() == opt ? "active" : "")" onclick="selectOption(this, 'Weight')">@opt</div>
                        }
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.GripSize))
            {
                var options = Model.GripSize.Split(',').Select(s => s.Trim()).ToList();
                <div class="spec-group">
                    <p class="spec-label">Kích thước cán:</p>
                    <div class="spec-pills" data-attribute="GripSize">
                        @foreach (var opt in options)
                        {
                            <div class="spec-pill @(options.First() == opt ? "active" : "")" onclick="selectOption(this, 'GripSize')">@opt</div>
                        }
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.Size))
            {
                var options = Model.Size.Split(',').Select(s => s.Trim()).ToList();
                <div class="spec-group">
                    <p class="spec-label">Kích thước:</p>
                    <div class="spec-pills" data-attribute="Size">
                        @foreach (var opt in options)
                        {
                            <div class="spec-pill @(options.First() == opt ? "active" : "")" onclick="selectOption(this, 'Size')">@opt</div>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="divider"></div>

        <!-- Qty & stock -->
        <div class="qty-row">
            <div class="qty-box">
                <button class="qty-btn" onclick="changeQty(-1)"><i class='bx bx-minus'></i></button>
                <span class="qty-val" id="qtyVal">1</span>
                <button class="qty-btn" onclick="changeQty(1)"><i class='bx bx-plus'></i></button>
            </div>
            <span class="stock-tag">
                <span class="stock-dot" style="background-color: @(Model.Stock > 0 ? "#10b981" : "#ef4444")"></span> 
                @(Model.Stock > 0 ? $"Còn hàng ({Model.Stock} chiếc)" : "Hết hàng")
            </span>
        </div>

        <!-- CTAs -->
        <div class="cta-row">
            <button class="btn-cart" onclick="addToCart(false)" @(Model.Stock <= 0 ? "disabled" : "")>
                <i class='bx bx-shopping-bag'></i> Thêm vào giỏ
            </button>
            <button class="btn-buy" onclick="addToCart(true)" @(Model.Stock <= 0 ? "disabled" : "")>Mua ngay</button>
        </div>

        <!-- Perks -->
        <div class="perks">
            <div class="perk"><i class='bx bx-package'></i> Miễn phí vận chuyển đơn từ 1.500.000 đ</div>
            <div class="perk"><i class='bx bx-revision'></i> Đổi trả trong 30 ngày nếu lỗi nhà sản xuất</div>
            <div class="perk"><i class='bx bx-shield-quarter'></i> Bảo hành chính hãng 12 tháng</div>
            <div class="perk"><i class='bx bx-credit-card'></i> Thanh toán an toàn — Visa, MoMo, ZaloPay</div>
        </div>
    </div>
</div>

<!-- TABS -->
<div class="tabs-section">
    <div class="tabs">
        <button class="tab active" onclick="switchTab('desc')">Mô tả</button>
        <button class="tab" onclick="switchTab('specs')">Thông số kỹ thuật</button>
        <button class="tab" onclick="switchTab('reviews')">Đánh giá (@Model.ReviewCount)</button>
        <button class="tab" onclick="switchTab('stringing')">Hướng dẫn căng dây</button>
    </div>

    <!-- DESC -->
    <div class="tab-content active" id="tab-desc">
        <div class="desc-text">
            @Html.Raw(Model.Description)
        </div>
    </div>

    <!-- SPECS -->
    <div class="tab-content" id="tab-specs">
        <table class="specs-table">
            <tr><td>Thương hiệu</td><td>@Model.Brand</td></tr>
            <tr><td>Dòng sản phẩm</td><td>@Model.CategoryName</td></tr>
            @if(!string.IsNullOrEmpty(Model.Stiffness)){<tr><td>Loại cán</td><td>@Model.Stiffness</td></tr>}
            @if(!string.IsNullOrEmpty(Model.Weight)){<tr><td>Trọng lượng</td><td>@Model.Weight</td></tr>}
            @if(!string.IsNullOrEmpty(Model.BalancePoint)){<tr><td>Điểm cân bằng</td><td>@Model.BalancePoint</td></tr>}
            @if(!string.IsNullOrEmpty(Model.Length)){<tr><td>Chiều dài</td><td>@Model.Length</td></tr>}
            @if(!string.IsNullOrEmpty(Model.Material)){<tr><td>Vật liệu khung</td><td>@Model.Material</td></tr>}
            @if(!string.IsNullOrEmpty(Model.RecommendedTension)){<tr><td>Độ căng dây khuyến nghị</td><td>@Model.RecommendedTension</td></tr>}
            @if(!string.IsNullOrEmpty(Model.IncludedString)){<tr><td>Dây kèm theo</td><td>@Model.IncludedString</td></tr>}
            @if(!string.IsNullOrEmpty(Model.GripSize)){<tr><td>Grip size</td><td>@Model.GripSize</td></tr>}
            @if(!string.IsNullOrEmpty(Model.Color)){<tr><td>Màu sắc</td><td>@Model.Color</td></tr>}
            @if(!string.IsNullOrEmpty(Model.Origin)){<tr><td>Xuất xứ</td><td>@Model.Origin</td></tr>}
            @if(!string.IsNullOrEmpty(Model.Warranty)){<tr><td>Bảo hành</td><td>@Model.Warranty</td></tr>}
        </table>
    </div>

    <!-- REVIEWS -->
    <div class="tab-content" id="tab-reviews">
        <div class="reviews-header">
            <div class="reviews-summary">
                <div>
                    <div class="big-rating">@Model.AverageRating.ToString("F1")</div>
                    <div class="stars" style="font-size:16px">
                        @for (int i = 1; i <= 5; i++)
                        {
                            @(i <= Math.Round(Model.AverageRating) ? "★" : "☆")
                        }
                    </div>
                    <div style="font-size:11px;color:var(--muted);margin-top:2px">@Model.ReviewCount đánh giá</div>
                </div>
                <div class="rating-bars">
                    @for (int i = 5; i >= 1; i--)
                    {
                        var count = Model.Reviews?.Count(r => r.Rating == i) ?? 0;
                        var percent = Model.ReviewCount > 0 ? (count * 100 / Model.ReviewCount) : 0;
                        <div class="rating-bar-row">@i★ <div class="rating-bar-track"><div class="rating-bar-fill" style="width:@percent%"></div></div> @percent%</div>
                    }
                </div>
            </div>
            <button class="btn-cart" style="max-width:160px;padding:10px 18px;font-size:13px">Viết đánh giá</button>
        </div>

        @if (Model.Reviews != null && Model.Reviews.Any())
        {
            <div class="slider-container">
                <button class="slider-btn prev" onclick="scrollSlider('reviewsSlider', -1)"><i class='bx bx-chevron-left'></i></button>
                <div class="reviews-slider standard-slider" id="reviewsSlider">
                    @foreach (var review in Model.Reviews)
                    {
                        <div class="review-card">
                            <div class="review-top">
                                <div class="review-avatar">@(review.UserName?.Substring(0, 1).ToUpper() ?? "U")</div>
                                <div>
                                    <div class="review-name">@review.UserName</div>
                                    <div class="review-date">@review.CreatedAt.ToString("dd MMMM, yyyy")</div>
                                </div>
                                <div class="review-stars" style="margin-left:auto">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        @(i <= review.Rating ? "★" : "☆")
                                    }
                                </div>
                            </div>
                            <div class="review-title">@review.Title</div>
                            <div class="review-body">@review.Comment</div>
                            @if (review.IsVerified)
                            {
                                <span class="review-tag">✅ Đã mua tại PBAO</span>
                            }
                            <div class="review-helpful">@review.HelpfulCount người thấy đánh giá này hữu ích</div>
                        </div>
                    }
                </div>
                <button class="slider-btn next" onclick="scrollSlider('reviewsSlider', 1)"><i class='bx bx-chevron-right'></i></button>
            </div>
        }
        else
        {
            <p style="text-align:center; padding: 20px; color: var(--muted);">Chưa có đánh giá nào cho sản phẩm này.</p>
        }
    </div>

    <!-- STRINGING -->
    <div class="tab-content" id="tab-stringing">
        <div class="desc-text">
            <h3>Độ căng dây khuyến nghị</h3>
            <p>Yonex khuyến nghị căng từ <strong>20–28 lbs</strong> tùy phong cách chơi:</p>
            <ul>
                <li><strong>20–22 lbs</strong> — Dành cho người mới, tập trung vào kiểm soát và độ bền dây.</li>
                <li><strong>23–25 lbs</strong> — Phù hợp hầu hết người chơi, cân bằng lực và kiểm soát.</li>
                <li><strong>26–28 lbs</strong> — Dành cho vận động viên nâng cao, tối đa lực đập.</li>
            </ul>
            <h3>Dây phù hợp</h3>
            <ul>
                <li><strong>BG80</strong> — Phổ biến nhất, phản lực cao, độ bền tốt.</li>
                <li><strong>BG65 Ti</strong> — Bền hơn BG80, phù hợp chơi nhiều.</li>
                <li><strong>Aerobite</strong> — Kết hợp hai loại dây, tối ưu spin và lực.</li>
            </ul>
            <h3>Lưu ý khi căng</h3>
            <p>Nên căng vợt bởi thợ có kinh nghiệm. PBAO cung cấp dịch vụ căng dây chuyên nghiệp tại cửa hàng với giá cực ưu đãi.</p>
        </div>
    </div>
</div>

<!-- RELATED PRODUCTS -->
<div class="related-section">
    <div class="section-title">Sản phẩm liên quan</div>
    <div class="slider-container">
        <button class="slider-btn prev" onclick="scrollSlider('relatedSlider', -1)"><i class='bx bx-chevron-left'></i></button>
        <div class="related-slider standard-slider" id="relatedSlider">
            @foreach (var item in relatedProducts)
            {
                var itemImagePath = !string.IsNullOrEmpty(item.Image) ? (item.Image.StartsWith("/") || item.Image.StartsWith("http") ? item.Image : (item.Image.StartsWith("~") ? item.Image : "~/img/" + item.Image)) : "~/img/no-img.jfif";
                <div class="related-card" onclick="window.location.href='/User/Store/Details/@item.Id'">
                    <div class="related-img">
                        <img src="@Url.Content(itemImagePath)" alt="@item.Name" style="width: 100%; height: 100%; object-fit: contain;" />
                    </div>
                    <div class="related-body">
                        <div class="related-cat">@item.CategoryName</div>
                        <div class="related-name">@item.Name</div>
                        <div class="related-stars">
                            @for (int i = 1; i <= 5; i++)
                            {
                                @(i <= Math.Round(item.AverageRating) ? "★" : "☆")
                            }
                        </div>
                        <div class="related-price">@item.Price.ToString("N0") đ</div>
                    </div>
                </div>
            }
        </div>
        <button class="slider-btn next" onclick="scrollSlider('relatedSlider', 1)"><i class='bx bx-chevron-right'></i></button>
    </div>
</div>

@section Scripts {
    <script src="~/js/favorite.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            if(typeof updateSliderButtons === 'function'){
                updateSliderButtons('reviewsSlider');
                updateSliderButtons('relatedSlider');
            }
        });

        function selectOption(el, attribute) {
            // Find the container for this attribute
            const container = el.closest('.spec-pills');
            // Remove active class from all pills in this container
            container.querySelectorAll('.spec-pill').forEach(p => p.classList.remove('active'));
            // Add active class to clicked pill
            el.classList.add('active');
        }

        function changeMainImage(thumb, url) {
            const mainImg = document.querySelector('#currentMainImg');
            if (mainImg) {
                mainImg.style.opacity = '0';
                setTimeout(() => {
                    mainImg.src = url;
                    mainImg.style.opacity = '1';
                }, 200);
            }
            
            // Update active thumb
            document.querySelectorAll('.thumb').forEach(t => t.classList.remove('active'));
            thumb.classList.add('active');
        }

        function changeQty(delta) {
            const qtyVal = document.getElementById('qtyVal');
            let current = parseInt(qtyVal.innerText);
            current += delta;
            if (current < 1) current = 1;
            qtyVal.innerText = current;
        }

        function switchTab(tabId) {
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
            
            document.querySelector(`.tab[onclick*="${tabId}"]`).classList.add('active');
            document.getElementById(`tab-${tabId}`).classList.add('active');
        }

        function addToCart(isRedirect) {
            const productId = @Model.Id;
            const quantity = parseInt(document.getElementById('qtyVal').innerText);

            // Collect selected variants
            let selectedVariants = [];
            document.querySelectorAll('.spec-pills').forEach(container => {
                const attr = container.getAttribute('data-attribute');
                const activePill = container.querySelector('.spec-pill.active');
                if (activePill) {
                    selectedVariants.push(`${attr}: ${activePill.innerText.trim()}`);
                }
            });
            const variantInfo = selectedVariants.join(' | ');

            fetch('/User/Cart/AddToCart', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `productId=${productId}&quantity=${quantity}&variant=${encodeURIComponent(variantInfo)}`
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    if (isRedirect) {
                        window.location.href = '/User/Cart';
                    } else {
                        // showNotification(data.message);
                        if (typeof showToast === 'function') {
                            showToast(data.message, 'success');
                        }
                        
                        // Update cart badge in layout
                        const cartBadge = document.getElementById('cart-count');
                        if (cartBadge) {
                            cartBadge.innerText = data.cartCount;
                            if (data.cartCount > 0) {
                                cartBadge.classList.add('show');
                            }
                        }
                    }
                } else {
                    if (typeof showToast === 'function') {
                        showToast(data.message, 'error');
                    }
                }
            })
            .catch(error => {
                console.error('Error:', error);
                if (typeof showToast === 'function') {
                    showToast('Có lỗi xảy ra khi thêm vào giỏ hàng.', 'error');
                }
            });
        }
    </script>
}
