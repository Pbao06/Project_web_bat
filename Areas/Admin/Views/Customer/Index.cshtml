@model Getdata1.Areas.Admin.ViewModels.CustomerIndexVM   

@{
    // ViewData["Title"] = "Customer page";
    // Layout = "~/Views/Shared/_Layout.cshtml"; Đảm bảo nó trỏ đúng về Layout bạn vừa làm
}
<title>@(ViewData["Title"] ?? "Default Title")</title>

@section Styles {
    @* nhúng css vao *@
    <link rel="stylesheet" href="~/css/Layout.css" />
    <link rel="stylesheet" href="~/css/order/Order_index.css" />
    <link rel="stylesheet" href="~/css/Paginationcss.css" />
    <link rel="stylesheet" href="~/css/Customer/Customercss.css" />
    
}

<main>

    @* mini box *@
    <div class="head-title">
        <div class="left">
            <h1>Order</h1>
            <ul class="Breakcrumb">
                <li>
                    <a href="#">Customer</a>
                </li>
                <li><i class='bx bx-chevron-right'></i></li>
                <li>
                    <a class="active" href="#">Customer</a>
                </li>
            </ul>
        </div>
    </div>

    <div class="table-data">
        <div class="order">
            <div class="head">
                <h3>Top Customers </h3>
                @* <div class="filter-wrapper">
                    <i class="bx bx-filter" onclick="toggleFilter()"></i>
                    <div class="filter-dropdown" id="filterDropdown" style="display:none">
                        <form method="get" asp-action="Index" asp-controller="Order">
                            <select name="status" onchange="this.form.submit()">
                                <option value="">All Orders</option>
                                <option value="Pending" selected="@(ViewBag.Status == "Pending")">Pending</option>
                                <option value="Paid" selected="@(ViewBag.Status == "Paid")">Paid</option>
                                <option value="Cancelled" selected="@(ViewBag.Status == "Cancelled")">Cancelled</option>
                            </select>
                        </form>
                    </div>
                </div> *@
            </div>
            <table>
                <thead>
                    <tr>

                        <th>User</th>
                        @* <th></th> *@
                        <th>Orders</th>
                        <th>Total Spent</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cus in Model.Customers)
                    {
                        <tr>


                            <td>
                                @cus.Name
                            </td>
                            <td>
                                @cus.OrderCount
                            </td>
                            <td>
                                @cus.TotalSpent.ToString("#,##0") ₫
                            </td>
                            <td>
                                <span class="status @cus.Status.ToString().ToLower()">
                                    @cus.Status
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @* pagination *@
            @* bottom of order Index.cshtml *@
             @await Html.PartialAsync("pagination_table", Model)


        </div>

    </div>
</main>
@section Scripts {
    <script>
        function toggleFilter() {
            var dropdown = document.getElementById('filterDropdown');
            dropdown.style.display = dropdown.style.display === 'none' ? 'block' : 'none';
        }

        // close when click outside
        document.addEventListener('click', function(e) {
            if (!e.target.closest('.filter-wrapper')) {
                document.getElementById('filterDropdown').style.display = 'none';
            }
        });
    </script>
}
