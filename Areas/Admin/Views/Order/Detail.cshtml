@model Getdata1.Areas.Admin.ViewModels.OrderVM
@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Order Details";
}

<main>
    <div class="head-title">
        <div class="left">
            <h1>Order Details</h1>
            <ul class="Breakcrumb">
                <li><a href="#">Admin</a></li>
                <li><i class='bx bx-chevron-right'></i></li>
                <li><a class="active" href="#">#@Model.OrderId</a></li>
            </ul>
        </div>
    </div>

    <div class="table-data">
        <div class="order">
            <div class="head">
                <h3>Transaction Record</h3>
                <a asp-action="Index" class="btn-back">
                    <i class='bx bx-chevron-left'></i>
                    <span>Back to List</span>
                </a>
            </div>

            <div class="order-info">
                <div class="info-item">
                    <span class="label"><i class='bx bx-hash'></i> Order ID</span>
                    <span class="value">#@Model.OrderId</span>
                </div>
                <div class="info-item">
                    <span class="label"><i class='bx bx-user'></i> Customer</span>
                    <span class="value">@Model.UserName</span>
                </div>
                <div class="info-item">
                    <span class="label"><i class='bx bx-calendar'></i> Date</span>
                    <span class="value">@Model.OrderDate.ToString("MMM dd, yyyy")</span>
                </div>
                <div class="info-item">
                    <span class="label"><i class='bx bx-pulse'></i> Status</span>
                    <span class="value">
                        <span class="status @Model.Status.ToString().ToLower()">
                            @Model.Status
                        </span>
                    </span>
                </div>
                <div class="info-item">
                    <span class="label"><i class='bx bx-dollar-circle'></i> Total Value</span>
                    <span class="value">@Model.TotalPrice.ToString("#,##0") ₫</span>
                </div>
            </div>

            <table>
                <thead>
                    <tr>
                        <th>Product Item</th>
                        <th>Qty</th>
                        <th>Unit Price</th>
                        <th>Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.ProductName</td>
                            <td>@item.Quantity</td>
                            <td>@item.Price.ToString("#,##0") ₫</td>
                            <td>@item.Subtotal.ToString("#,##0") ₫</td>
                        </tr>
                    }
                    <tr class="total-row">
                        <td colspan="3" style="text-align: right; font-weight: 600;">Grand Total</td>
                        <td style="font-weight: 800; color: var(--accent); font-size: 18px;">@Model.TotalPrice.ToString("#,##0") ₫</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</main>
