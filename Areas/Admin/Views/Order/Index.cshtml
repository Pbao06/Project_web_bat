@model Getdata1.Areas.Admin.ViewModels.OrderPageVM
@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Orders";
}

<main>
    <div class="head-title">
        <div class="left">
            <h1>Orders</h1>
            <ul class="Breakcrumb">
                <li><a href="#">Admin</a></li>
                <li><i class='bx bx-chevron-right'></i></li>
                <li><a class="active" href="#">Order History</a></li>
            </ul>
        </div>
    </div>
    
    <div class="table-data">
        <div class="order">
            <div class="head">
                <h3>Transactions</h3>
                <div class="filter-wrapper" style="position: relative;">
                    <i class="bx bx-filter" onclick="toggleFilter()" style="font-size: 20px; cursor: pointer;"></i>
                    <div id="filterDropdown" style="display:none; position: absolute; right: 0; top: 30px; background: #fff; border: 0.5px solid var(--border); border-radius: 12px; padding: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); z-index: 100;">
                        <form method="get" asp-action="Index" asp-controller="Order">
                            <select name="status" onchange="this.form.submit()" style="border: none; outline: none; font-size: 13px; background: transparent; cursor: pointer;">
                                <option value="">All Orders</option>
                                <option value="Pending" selected="@(ViewBag.Status == "Pending")">Pending</option>
                                <option value="Paid" selected="@(ViewBag.Status == "Paid")">Paid</option>
                                <option value="Cancelled" selected="@(ViewBag.Status == "Cancelled")">Cancelled</option>
                            </select>
                        </form>
                    </div>
                </div>
            </div>
            <table>
                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Date</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach(var order in Model.Orders)
                    {
                      <tr>
                            <td>@order.UserName</td>
                            <td>@order.OrderDate.ToString("MMM dd, yyyy HH:mm")</td>
                            <td>@order.TotalPrice.ToString("#,##0") đ</td>
                            <td>
                                <span class="status @order.Status.ToString().ToLower()">
                                    @order.Status
                                </span>
                            </td>
                            <td class="btn-Edit-Delete-Detail">
                                <a asp-action="Detail" asp-route-id="@order.OrderId" title="Chi tiết"><i class='bx bx-show'></i></a>
                                @if(order.Status == Getdata1.Models.Enums.OrderStatus.Pending)
                                {
                                    <a href="javascript:void(0)" 
                                       onclick="confirmUpdateStatus(@order.OrderId, 'Paid', '@order.UserName')" 
                                       title="Duyệt đơn" style="color: var(--blue);">
                                        <i class='bx bx-check-circle'></i>
                                    </a>

                                    <a href="javascript:void(0)" 
                                       onclick="confirmUpdateStatus(@order.OrderId, 'Cancelled', '@order.UserName')" 
                                       title="Hủy đơn" style="color: var(--red);">
                                        <i class='bx bx-x-circle'></i>
                                    </a>
                                }
                            </td>
                      </tr>
                    }
                </tbody>
            </table>

            @await Html.PartialAsync("pagination_table", Model)
        </div>
    </div>
</main>

@section Scripts {
    <script>
        function confirmUpdateStatus(id, status, userName) {
            const isPaid = status === 'Paid';
            const title = isPaid ? 'Xác nhận duyệt đơn' : 'Xác nhận hủy đơn';
            const content = isPaid 
                ? `Bạn có chắc chắn muốn <strong>Duyệt</strong> đơn hàng của khách hàng <strong>${userName}</strong>?`
                : `Bạn có chắc chắn muốn <strong>Hủy</strong> đơn hàng của khách hàng <strong>${userName}</strong>?`;
            const confirmText = isPaid ? 'Duyệt đơn' : 'Hủy đơn';
            const btnClass = isPaid ? 'btn-primary' : 'btn-danger';

            showGlobalModal({
                title: title,
                content: content,
                confirmText: confirmText,
                cancelText: 'Hủy',
                confirmClass: btnClass,
                onConfirm: function () {
                    window.location.href = `@Url.Action("UpdateStatus", "Order")?id=${id}&status=${status}`;
                }
            });
        }
    </script>
}
