@model dynamic

<div class="pagination-container">
    <div class="pagination-controls-wrapper">

        @* Previous Button *@
        <div class="prev-box">
            @if (Model.CurrentPage > 1)
            {
                <a href="?page=@(Model.CurrentPage - 1)&status=@Model.Status" class="page-btn">
                    <i class='bx bx-chevron-left'></i> Previous
                </a>
            }
            else
            {
                <span class="page-btn disabled"><i class='bx bx-chevron-left'></i> Previous</span>
            }
        </div>

        @* Page Numbers Logic *@
        <div class="page-numbers">
            @{
                int startPage = Math.Max(1, Model.CurrentPage - 1);
                int endPage = Math.Min(Model.TotalPages, startPage + 2);

                if (startPage > 1)
                {
                    <a href="?page=1&status=@Model.Status" class="page-num">01</a>
                    if (startPage > 2)
                    {

                        <span class="dots">...</span>
                    }
                }

                for (int i = startPage; i <= endPage; i++)
                {
                    <a href="?page=@i&status=@Model.Status"
                       class="page-num @(i == Model.CurrentPage ? "active" : "")">
                        @i.ToString("D2")
                    </a>
                }

                if (endPage < Model.TotalPages)
                {
                    if (endPage < Model.TotalPages - 1)
                    {

                        <span class="dots">...</span>
                    }
                    <a href="?page=@Model.TotalPages&status=@Model.Status" class="page-num">@Model.TotalPages.ToString("D2")</a>
                }
            }
        </div>

        @* Next Button *@
        <div class="next-box">
            @if (Model.CurrentPage < Model.TotalPages)
            {
                <a href="?page=@(Model.CurrentPage + 1)&status=@Model.Status" class="page-btn">
                    Next <i class='bx bx-chevron-right'></i>
                </a>
            }
            else
            {
                <span class="page-btn disabled">Next <i class='bx bx-chevron-right'></i></span>
            }
        </div>
    </div>
</div>