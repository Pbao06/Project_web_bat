@model dynamic

<div class="pagination-container">
    @if (Model.CurrentPage > 1)
    {
        <a href="?page=@(Model.CurrentPage - 1)&status=@Model.Status" class="pagination-item">
            <i class='bx bx-chevron-left'></i>
        </a>
    }
    else
    {
        <span class="pagination-item disabled"><i class='bx bx-chevron-left'></i></span>
    }

    @{
        int startPage = Math.Max(1, Model.CurrentPage - 1);
        int endPage = Math.Min(Model.TotalPages, startPage + 2);

        if (startPage > 1)
        {
            <a href="?page=1&status=@Model.Status" class="pagination-item">1</a>
            if (startPage > 2)
            {
                <span class="pagination-ellipsis">...</span>
            }
        }

        for (int i = startPage; i <= endPage; i++)
        {
            <a href="?page=@i&status=@Model.Status"
               class="pagination-item @(i == Model.CurrentPage ? "active" : "")">
                @i
            </a>
        }

        if (endPage < Model.TotalPages)
        {
            if (endPage < Model.TotalPages - 1)
            {
                <span class="pagination-ellipsis">...</span>
            }
            <a href="?page=@Model.TotalPages&status=@Model.Status" class="pagination-item">@Model.TotalPages</a>
        }
    }

    @if (Model.CurrentPage < Model.TotalPages)
    {
        <a href="?page=@(Model.CurrentPage + 1)&status=@Model.Status" class="pagination-item">
            <i class='bx bx-chevron-right'></i>
        </a>
    }
    else
    {
        <span class="pagination-item disabled"><i class='bx bx-chevron-right'></i></span>
    }
</div>