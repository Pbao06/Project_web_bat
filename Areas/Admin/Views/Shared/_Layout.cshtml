<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Pbao Admin</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Icons -->
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>

    <!-- Custom Admin Styles -->
    <link rel="stylesheet" href="~/css/AdminCustom.css">

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @using Microsoft.AspNetCore.Mvc.Rendering
    @using Microsoft.AspNetCore.Identity
    @using Getdata1.Models
    @inject UserManager<User> UserManager
    @inject SignInManager<User> SignInManager
    @{
        string IsActive(string controller)
        {
            var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
            return string.Equals(controller, currentController, StringComparison.OrdinalIgnoreCase) ? "active" : "";
        }

        var currentUser = await UserManager.GetUserAsync(User);
        var initials = currentUser?.UserName?.Substring(0, 1).ToUpper() ?? "A";
    }

    <!-- SIDEBAR -->
    <section id="sidebar">
        <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="brand">
            <i class='bx bx-trophy'></i>
            <span>Pbao Admin</span>
        </a>
        
        <ul class="side-menu">
            <li class="@IsActive("Home")">
                <a asp-area="Admin" asp-controller="Home" asp-action="Index">
                    <i class='bx bx-grid-alt'></i>
                    <span>Dashboard</span>
                </a>
            </li>
            <li class="@IsActive("ProductManual")">
                <a asp-area="Admin" asp-controller="ProductManual" asp-action="Index">
                    <i class='bx bx-package'></i>
                    <span>Inventory</span>
                </a>
            </li>
            <li class="@IsActive("Order")">
                <a asp-area="Admin" asp-controller="Order" asp-action="Index">
                    <i class='bx bx-shopping-bag'></i>
                    <span>Orders</span>
                </a>
            </li>
            <li class="@IsActive("Customer")">
                <a asp-area="Admin" asp-controller="Customer" asp-action="Index">
                    <i class='bx bx-user-circle'></i>
                    <span>Customers</span>
                </a>
            </li>
        </ul>

        <ul class="side-menu">
            <li>
                <a asp-area="User" asp-controller="Home" asp-action="Index">
                    <i class='bx bx-globe'></i>
                    <span>View Store</span>
                </a>
            </li>
            <li>
                <a href="#">
                    <i class='bx bx-cog'></i>
                    <span>Settings</span>
                </a>
            </li>
            <li>
                <a @*asp-area="User" asp-controller="Account" asp-action="Logout"*@ href="javascript:void(0)" onclick="Logout()" class="logout">
                    <i class='bx bx-log-out'></i>
                    <span>Logout</span>
                </a>
            </li>
        </ul>
    </section>

    <!-- CONTENT -->
    <section id="content">
        <!-- NAVBAR -->
        <nav>
            <i class='bx bx-menu'></i>
            
            @* <form action="#">
                <div class="form-input">
                    <input type="search" placeholder="Search anything...">
                    <button type="submit"><i class='bx bx-search'></i></button>
                </div>
            </form> *@

            @await Component.InvokeAsync("AdminNotification")
            
            <a asp-area="User" asp-controller="Profile" asp-action="MyAccount" class="profile" title="@currentUser?.UserName">
                <div class="avatar-initials">@initials</div>
            </a>
        </nav>

        <!-- MAIN -->
        @RenderBody()
    </section>

    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/Admin_script.js"></script>
    @await Html.PartialAsync("_GlobalModal")
    @await RenderSectionAsync("Scripts", required: false)
    
    @if (TempData["Notification"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const data = @Html.Raw(TempData["Notification"]);
                showGlobalModal({
                    title: data.Type === 'success' ? 'Thành công' : (data.Type === 'error' ? 'Lỗi' : 'Thông báo'),
                    content: data.Message,
                    confirmText: 'Đóng',
                    hideCancel: true
                });
            });
        </script>
    }

    <script>

         function Logout() {
                console.log("Clicked");
            showGlobalModal({
                title: 'Đăng xuất',
                content: 'Bạn có chắc muốn đăng xuất không?',
                confirmText: 'Đăng xuất',
                cancelText: 'Hủy',
                onConfirm: function() {
                    // Đóng modal
                    closeGlobalModal();
                     setTimeout(function () {
                         window.location.href = '/User/Account/Logout';
                     }, 300); // 300ms hoặc bằng thời gian animation
                    // Đẩy sang trang logout để xóa cookie user redirect về login 
                    // window.location.href = '/User/Account/Logout';
                }
            });
         }
        document.addEventListener('DOMContentLoaded', function() {
            if (typeof initSidebar === 'function') initSidebar();
            if (typeof initNavbar === 'function') initNavbar();
        });
    </script>
</body>
</html>