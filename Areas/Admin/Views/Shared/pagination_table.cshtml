@model dynamic

<div class="pagination-container">
    @if (Model.CurrentPage > 1)
    {
        <a href="?page=@(Model.CurrentPage - 1)@(Context.Request.QueryString.HasValue ? Context.Request.QueryString.Value.Replace("?page=" + Model.CurrentPage, "").Replace("&page=" + Model.CurrentPage, "") : "")" class="pagination-item">
            <i class='bx bx-chevron-left'></i>
        </a>
    }
    else
    {
        <span class="pagination-item disabled"><i class='bx bx-chevron-left'></i></span>
    }

    @{
        int startPage = Math.Max(1, Model.CurrentPage - 1);
        int endPage = Math.Min(Model.TotalPages, startPage + 2);

        for (int i = startPage; i <= endPage; i++)
        {
            <a href="?page=@i" class="pagination-item @(i == Model.CurrentPage ? "active" : "")">
                @i
            </a>
        }
    }

    @if (Model.CurrentPage < Model.TotalPages)
    {
        <a href="?page=@(Model.CurrentPage + 1)" class="pagination-item">
            <i class='bx bx-chevron-right'></i>
        </a>
    }
    else
    {
        <span class="pagination-item disabled"><i class='bx bx-chevron-right'></i></span>
    }
</div>