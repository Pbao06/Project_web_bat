@model Getdata1.Areas.Admin.ViewModels.DashboardVM
@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Dashboard";
}

<main>
    <div class="head-title">
        <div class="left">
            <h1>Dashboard</h1>
            <ul class="Breakcrumb">
                <li><a href="#">Admin</a></li>
                <li><i class='bx bx-chevron-right'></i></li>
                <li><a class="active" href="#">Overview</a></li>
            </ul>
        </div>
        @* <a href="#" class="btn-download">
            <span class="text">Export Report</span>
        </a> *@
    </div>

    <ul class="box-info">
        <li>
            <i class='bx bx-shopping-bag'></i>
            <span class="text">
                <h3>@Model.TotalOrders</h3>
                <p>New Orders</p>
            </span>
        </li>
        <li>
            <i class='bx bx-error-circle'></i>
            <span class="text">
                <h3>@Model.LowStockProducts.Count</h3>
                <p>Low Stock</p>
            </span>
        </li>
        <li>
            <i class='bx bx-dollar-circle'></i>
            <span class="text">
                <h3>@Model.TotalSales.ToString("#,##0") đ</h3>
                <p>Total Revenue</p>
            </span>
        </li>
    </ul>

    <div class="table-data">
        <div class="order">
            <div class="head">
                <h3>Recent Transactions</h3>
                <div class="filter-wrapper" style="position: relative;">
                    <i class="bx bx-filter" onclick="toggleFilter()" style="font-size: 20px; cursor: pointer;"></i>
                    <div id="filterDropdown" style="display:none; position: absolute; right: 0; top: 30px; background: #fff; border: 0.5px solid var(--border); border-radius: 12px; padding: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); z-index: 100;">
                        <form method="get" asp-action="Index" asp-controller="Home">
                            <select name="status" onchange="this.form.submit()" style="border: none; outline: none; font-size: 13px; background: transparent; cursor: pointer;">
                                <option value="">All Orders</option>
                                <option value="Pending" selected="@(ViewBag.Status == "Pending")">Pending</option>
                                <option value="Paid" selected="@(ViewBag.Status == "Paid")">Paid</option>
                                <option value="Cancelled" selected="@(ViewBag.Status == "Cancelled")">Cancelled</option>
                            </select>
                        </form>
                    </div>
                </div>
            </div>
            <table>
                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Date</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.RecentOrders)
                    {
                        <tr>
                            <td>
                                <div style="display: flex; align-items: center;">
                                    @* <img src="~/img/no-img.jfif" alt="@order.User?.UserName"> *@
                                    <p>@order.User.UserName</p>
                                </div>
                            </td>
                            <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                            <td><span class="status @(order.Status.ToString().ToLower())">@order.Status.ToString()</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="todo">
            <div class="head">
                <h3>Action Items</h3>
            </div>
            <ul class="todo-list" id="todo-list">
                @foreach (var product in Model.LowStockProducts)
                {
                    <li>
                        <p><strong>@product.Name</strong> is low on stock (@product.Stock remaining)</p>
                        <i class="bx bx-check done-btn"></i>
                    </li>
                }

                @if (Model.PendingOrders > 0)
                {
                    <li>
                        <p>You have <strong>@Model.PendingOrders</strong> pending orders to review</p>
                        <i class="bx bx-check done-btn"></i>
                    </li>
                }
            </ul>

            <div id="todo-empty" style="display:none; text-align: center; padding: 20px; color: var(--muted); font-size: 13px;">
                <i class='bx bx-check-double' style="font-size: 24px; display: block; margin-bottom: 8px;"></i>
                <p>All tasks completed</p>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const list = document.getElementById('todo-list');
            const empty = document.getElementById('todo-empty');
            
            function checkEmpty() {
                if (list && list.children.length === 0) {
                    empty.style.display = 'block';
                }
            }

            checkEmpty();

            document.querySelectorAll('.done-btn').forEach(btn => {
                btn.addEventListener('click', function () {
                    const li = this.closest('li');
                    li.style.opacity = '0';
                    li.style.transform = 'translateX(20px)';
                    li.style.transition = 'all 0.3s ease';
                    
                    setTimeout(() => {
                        li.remove();
                        checkEmpty();
                    }, 300);
                });
            });
        });
    </script>
}