@model Getdata1.Models.Product
@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Edit Product";
}

<main>
    <div class="head-title">
        <div class="left">
            <h1>Edit Product</h1>
            <ul class="Breakcrumb">
                <li><a href="#">Inventory</a></li>
                <li><i class='bx bx-chevron-right'></i></li>
                <li><a class="active" href="#">Update Details</a></li>
            </ul>
        </div>
    </div>

    <div class="table-data">
        <div class="order">
            <div class="head">
                <h3>Product Record</h3>
            </div>
            
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="Image" />

                <div class="form-container" style="display: grid; grid-template-columns: 350px 1fr; gap: 40px;">
                    
                    <!-- IMAGE COLUMN -->
                    <div class="image-section">
                        <label>Product Imagery</label>
                        
                        <div class="image-main-preview">
                            <img src="@(string.IsNullOrEmpty(Model.Image) ? "/img/no-img.jfif" : Model.Image)" id="img-display" alt="Preview">
                        </div>

                        <div class="image-thumbnails">
                            @if (!string.IsNullOrEmpty(Model.Image))
                            {
                                <div class="thumb-item active" onclick="changeImage('@Model.Image', this)">
                                    <img src="@Model.Image">
                                </div>
                            }

                            @if (Model.ProductImages != null)
                            {
                                @foreach (var galleryImg in Model.ProductImages)
                                {
                                    <div class="thumb-item" id="gallery-item-@galleryImg.Id" onclick="changeImage('@galleryImg.Url', this)">
                                        <img src="@galleryImg.Url">
                                        <button type="button" class="btn-delete" onclick="deleteImage(@galleryImg.Id)">
                                            <i class='bx bx-x'></i>
                                        </button>
                                    </div>
                                }
                            }
                        </div>

                        <div class="upload-controls">
                            <label for="file-upload" class="btn-upload-label">
                                <i class='bx bx-camera'></i> Change Cover Image
                            </label>
                            <input id="file-upload" type="file" asp-for="ImageFile" style="display:none;" onchange="previewImage(this)">

                            <label for="gallery-upload" class="btn-upload-label">
                                <i class='bx bx-plus-circle'></i> Add Gallery Photos
                            </label>
                            <input id="gallery-upload" type="file" asp-for="GalleryFiles" multiple style="display:none;" onchange="updateGalleryCount(this)">
                        </div>
                    </div>

                    <!-- DATA COLUMN -->
                    <div class="form-content">
                        <div class="form-section-title" style="margin-top: 0;">
                            <h4>General Information</h4>
                        </div>

                        <div class="form-group">
                            <label asp-for="Name">Product Name</label>
                            <input asp-for="Name" class="my-input" placeholder="e.g. Yonex Astrox 100ZZ">
                        </div>

                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                            <div class="form-group">
                                <label asp-for="Price">Price (₫)</label>
                                <input asp-for="Price" class="my-input">
                            </div>
                            <div class="form-group">
                                <label asp-for="Brand">Brand</label>
                                <input asp-for="Brand" class="my-input">
                            </div>
                            <div class="form-group">
                                <label asp-for="Stock">Stock Level</label>
                                <input asp-for="Stock" class="my-input">
                            </div>
                            <div class="form-group">
                                <label asp-for="CategoryId">Category</label>
                                <select asp-for="CategoryId" asp-items="@(ViewData["Category"] as SelectList)" class="my-input">
                                    <option value="">Select Category</option>
                                </select>
                            </div>
                        </div>

                        <div class="form-group">
                            <label asp-for="Description">Description</label>
                            <textarea asp-for="Description" class="my-input" rows="5"></textarea>
                        </div>
                    </div>
                </div>

                <div id="specs-container">
                    <div class="form-section-title">
                        <h4>Technical Specifications</h4>
                    </div>

                    <div id="racket-specs" class="spec-section" style="display: none; grid-template-columns: repeat(3, 1fr); gap: 20px; padding: 0 24px;">
                        <div class="form-group">
                            <label asp-for="Stiffness">Stiffness</label>
                            <input asp-for="Stiffness" class="my-input" placeholder="e.g. Cứng, Trung bình">
                            <small class="form-text">Phân tách bằng dấu phẩy nếu có nhiều loại</small>
                        </div>
                        <div class="form-group">
                            <label asp-for="Weight">Weight/Grip</label>
                            <input asp-for="Weight" class="my-input" placeholder="e.g. 3U, 4U">
                            <small class="form-text">Phân tách bằng dấu phẩy nếu có nhiều loại</small>
                        </div>
                        <div class="form-group">
                            <label asp-for="BalancePoint">Balance Point</label>
                            <input asp-for="BalancePoint" class="my-input">
                        </div>
                        <div class="form-group">
                            <label asp-for="RecommendedTension">Tension</label>
                            <input asp-for="RecommendedTension" class="my-input">
                        </div>
                        <div class="form-group">
                            <label asp-for="GripSize">Grip Size</label>
                            <input asp-for="GripSize" class="my-input" placeholder="e.g. G5, G6">
                            <small class="form-text">Phân tách bằng dấu phẩy nếu có nhiều loại</small>
                        </div>
                        <div class="form-group">
                            <label asp-for="Length">Length</label>
                            <input asp-for="Length" class="my-input">
                        </div>
                    </div>

                    <div id="shoe-specs" class="spec-section" style="display: none; grid-template-columns: repeat(2, 1fr); gap: 20px; padding: 0 24px;">
                        <div class="form-group">
                            <label asp-for="Size">Size (EU/US)</label>
                            <input asp-for="Size" class="my-input" placeholder="e.g. 39, 40, 41">
                            <small class="form-text">Phân tách bằng dấu phẩy nếu có nhiều size</small>
                        </div>
                    </div>

                    <div id="shuttle-specs" class="spec-section" style="display: none; grid-template-columns: repeat(2, 1fr); gap: 20px; padding: 0 24px;">
                        <div class="form-group">
                            <label asp-for="Speed">Speed</label>
                            <input asp-for="Speed" class="my-input" placeholder="e.g. 76, 77">
                            <small class="form-text">Phân tách bằng dấu phẩy nếu có nhiều loại</small>
                        </div>
                    </div>

                    <div id="general-specs" class="spec-section" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; padding: 24px;">
                        <div class="form-group">
                            <label asp-for="Color">Color</label>
                            <input asp-for="Color" class="my-input" placeholder="e.g. Red, Blue, Black">
                            <small class="form-text">Phân tách bằng dấu phẩy nếu có nhiều màu</small>
                        </div>
                        <div class="form-group">
                            <label asp-for="Material">Material</label>
                            <input asp-for="Material" class="my-input">
                        </div>
                        <div class="form-group">
                            <label asp-for="Origin">Origin</label>
                            <input asp-for="Origin" class="my-input">
                        </div>
                        <div class="form-group">
                            <label asp-for="Warranty">Warranty</label>
                            <input asp-for="Warranty" class="my-input">
                        </div>
                    </div>
                </div>

                <div class="form-footer">
                    <button type="submit" class="btn-save-product">
                        <i class='bx bx-refresh'></i>
                        <span>Apply Updates</span>
                    </button>
                    <a asp-action="Index" class="btn-cancel">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</main>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        function deleteImage(imageId) {
            if (confirm("Delete this image from gallery?")) {
                $.ajax({
                    url: '/ProductManual/DeleteImage',
                    type: 'POST',
                    data: { id: imageId },
                    success: function (response) {
                        if (response.success) {
                            $("#gallery-item-" + imageId).fadeOut(300, function() {
                                $(this).remove();
                            });
                        }
                    }
                });
            }
        }

        function changeImage(url, el) {
            document.getElementById('img-display').src = url;
            document.querySelectorAll('.thumb-item').forEach(item => item.classList.remove('active'));
            el.classList.add('active');
        }

        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('img-display').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            const categorySelect = document.getElementById('CategoryId');
            
            function updateFields() {
                const selectedOption = categorySelect.options[categorySelect.selectedIndex];
                const categoryText = selectedOption ? selectedOption.text.toLowerCase() : '';
                
                document.getElementById('racket-specs').style.display = 'none';
                document.getElementById('shoe-specs').style.display = 'none';
                document.getElementById('shuttle-specs').style.display = 'none';
                
                if (categoryText.includes('racket') || categoryText.includes('vợt')) {
                    document.getElementById('racket-specs').style.display = 'grid';
                } else if (categoryText.includes('shoe') || categoryText.includes('giày')) {
                    document.getElementById('shoe-specs').style.display = 'grid';
                } else if (categoryText.includes('shuttle') || categoryText.includes('cầu')) {
                    document.getElementById('shuttle-specs').style.display = 'grid';
                }
            }

            categorySelect.addEventListener('change', updateFields);
            updateFields();
        });
    </script>
}