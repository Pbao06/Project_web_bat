@model Getdata1.Areas.Admin.ViewModels.ProductFilterVM
@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Inventory";
}

<main>
    <div class="head-title">
        <div class="left">
            <h1>Inventory</h1>
            <ul class="Breakcrumb"> 
                <li><a asp-action="Index">Admin</a></li>
                <li><i class='bx bx-chevron-right'></i></li>
                <li><a class="active" href="#">Products</a></li>
            </ul>
        </div>
        <a asp-action="Create" class="btn-download">
            <i class='bx bx-plus'></i>
            <span>Add Product</span>
        </a>
    </div>

    <ul class="box-info">
        <li>
            <i class='bx bx-package'></i>
            <span class="text">
                <h3>@ViewBag.TotalProducts</h3>
                <p>Total Items</p>
            </span>
        </li>
        <li>
            <i class='bx bx-trending-up'></i>
            <span class="text">
                <h3>3</h3>
                <p>Trending</p>
            </span>
        </li>
    </ul>

    <div class="table-data">
        <div class="order">
            <div class="head">
                <h3>Product List</h3>
            </div>

            <form method="get" asp-action="Index" asp-controller="ProductManual" class="filter-card">
                <div class="filter-content">
                    <div class="filter-row">
                        <div class="filter-group search-box">
                            <i class='bx bx-search'></i>
                            <input type="text" asp-for="Name" placeholder="Search by name..." onchange="this.form.submit()" />
                        </div>

                        <div class="filter-group select-box">
                            <select asp-for="CategoryId" asp-items="@(ViewBag.Category as SelectList)" onchange="this.form.submit()">
                                <option value="">All Categories</option>
                            </select>
                        </div>
                        
                        <div class="filter-actions">
                            <a asp-action="Index" class="btn-reset">Reset</a>
                            <button type="submit" class="btn-primary">Filter</button>
                        </div>
                    </div>

                    <div class="filter-row">
                        <div class="filter-group range-container">
                            <span class="filter-tag">Price</span>
                            <div class="range-inputs">
                                <input type="number" asp-for="MinPrice" placeholder="Min" onchange="this.form.submit()" />
                                <span class="range-divider"></span>
                                <input type="number" asp-for="MaxPrice" placeholder="Max" onchange="this.form.submit()" />
                            </div>
                        </div>

                        <div class="filter-group range-container">
                            <span class="filter-tag">Stock</span>
                            <div class="range-inputs">
                                <input type="number" name="MinStock" value="@Model.MinStock" placeholder="Min" onchange="this.form.submit()" />
                                <span class="range-divider"></span>
                                <input type="number" name="MaxStock" value="@Model.MaxStock" placeholder="Max" onchange="this.form.submit()" />
                            </div>
                        </div>
                    </div>
                </div>
            </form>
           
            <table>
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Price</th>
                        <th>Brand</th>
                        <th>Stock</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Products) {
                        <tr>
                            <td>
                                <div style="display: flex; align-items: center;">
                                    @if (!string.IsNullOrEmpty(item.Image))
                                    {
                                        <img src="@item.Image" alt="@item.Name" />
                                    }
                                    else
                                    {
                                        <img src="~/img/no-img.jfif" alt="Default" />
                                    }
                                    <p>@item.Name</p>
                                </div>
                            </td>
                            <td>@item.Price.ToString("#,##0") ₫</td>
                            <td>@item.Brand</td>
                            <td>@item.Stock</td>
                            <td>
                                @if (item.Stock > 10)
                                {
                                    <span class="status instock">In Stock</span>
                                }
                                else if (item.Stock > 0)
                                {
                                    <span class="status lowstock">Low Stock</span>
                                }
                                else
                                {
                                    <span class="status outstock">Out of Stock</span>
                                }
                            </td>
                            <td class="btn-Edit-Delete-Detail">
                                <a asp-action="Edit" asp-route-id="@item.Id"><i class='bx bx-edit-alt'></i></a>
                                <a asp-action="Detail" asp-route-id="@item.Id"><i class='bx bx-show'></i></a>
                                <a asp-action="Delete" asp-route-id="@item.Id"><i class='bx bx-trash'></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @{
                var pagination = new Getdata1.Models.PaginationVM
                {
                    CurrentPage = Model.CurrentPage,
                    TotalPages = Model.TotalPages,
                    ActionName = "Index",
                    RouteValues = new Dictionary<string, string> 
                    { 
                        { "Name", Model.Name ?? "" },
                        { "CategoryId", Model.CategoryId?.ToString() ?? "" },
                        { "MinPrice", Model.MinPrice?.ToString() ?? "" },
                        { "MaxPrice", Model.MaxPrice?.ToString() ?? "" },
                        { "MinStock", Model.MinStock?.ToString() ?? "" },
                        { "MaxStock", Model.MaxStock?.ToString() ?? "" }
                    }
                };
            }
            <partial name="_Pagination" model="pagination" />
        </div>
    </div>
</main>
