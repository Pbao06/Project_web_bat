@model Getdata1.Areas.Admin.ViewModels.ProductFilterVM
@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Inventory";
}

<main>
    <div class="head-title">
        <div class="left">
            <h1>Inventory</h1>
            <ul class="Breakcrumb"> 
                <li><a asp-action="Index">Admin</a></li>
                <li><i class='bx bx-chevron-right'></i></li>
                <li><a class="active" href="#">Products</a></li>
            </ul>
        </div>
        <a asp-action="Create" class="btn-download">
            <i class='bx bx-plus'></i>
            <span>Add Product</span>
        </a>
    </div>

    <ul class="box-info">
        <li>
            <i class='bx bx-package'></i>
            <span class="text">
                <h3>@ViewBag.TotalProducts</h3>
                <p>Total Items</p>
            </span>
        </li>
        <li>
            <i class='bx bx-trending-down'></i>
            <span class="text">
                @if(ViewBag.Soluonglowstock !=0)
                {
                    <h3>@ViewBag.Soluonglowstock</h3>
                    <p>Low Stock</p>
                }
                else
                {
                    <h3>0</h3>
                    <p>Low Stock</p>
                }
            </span>
        </li>
        <li>
            <i class='bx bx-trending-up'></i>
            <span class="text">
                @if (ViewBag.Top1 != null)
                {
                    <h3>@ViewBag.Top1.TotalSold</h3>
                    <p>@ViewBag.Top1.ProductName</p>
                    
                }
                else
                {
                    <h3>0</h3>
                    <p>Chưa có sản phẩm nào bán ra!</p>
                }

               
            </span>
        </li>
    </ul>

    <div class="table-data">
        <div class="order">
            <div class="head">
                <h3>Product List</h3>
            </div>

            <form method="get" asp-action="Index" asp-controller="ProductManual" class="filter-card">
                <div class="filter-content">
                    <div class="filter-row">
                        <div class="filter-group search-box">
                            <i class='bx bx-search'></i>
                            <input type="text" asp-for="Name" placeholder="Search by name..." onchange="this.form.submit()" />
                        </div>

                        <div class="filter-group select-box">
                            <select asp-for="CategoryId" asp-items="@(ViewBag.Category as SelectList)" onchange="this.form.submit()">
                                <option value="">All Categories</option>
                            </select>
                        </div>
                        
                        <div class="filter-actions">
                            <a asp-action="Index" class="btn-reset">Reset</a>
                            <button type="submit" class="btn-primary">Filter</button>
                        </div>
                    </div>

                    <div class="filter-row">
                        <div class="filter-group range-container">
                            <span class="filter-tag">Price</span>
                            <div class="range-inputs">
                                <input type="number" asp-for="MinPrice" placeholder="Min" onchange="this.form.submit()" />
                                <span class="range-divider"></span>
                                <input type="number" asp-for="MaxPrice" placeholder="Max" onchange="this.form.submit()" />
                            </div>
                        </div>

                        <div class="filter-group range-container">
                            <span class="filter-tag">Stock</span>
                            <div class="range-inputs">
                                <input type="number" name="MinStock" value="@Model.MinStock" placeholder="Min" onchange="this.form.submit()" />
                                <span class="range-divider"></span>
                                <input type="number" name="MaxStock" value="@Model.MaxStock" placeholder="Max" onchange="this.form.submit()" />
                            </div>
                        </div>

                        @* filter theo status *@
                        <div class="filter-group select-box">
                            <select asp-for="Status" onchange="this.form.submit()">
                                <option value="">All Status</option>
                                <option value="instock">InStock</option>
                                <option value="lowstock">Low Stock</option>
                                <option value="outstock">Out of Stock</option>
                            </select>
                        </div>
                    </div>
                </div>
            </form>
           
            <table>
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Price</th>
                        <th>Brand</th>
                        <th>Stock</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Products) {
                        var statusClass = item.Stock > 10 ? "instock" : (item.Stock > 0 ? "lowstock" : "outstock");
                        var statusText = item.Stock > 10 ? "In Stock" : (item.Stock > 0 ? "Low Stock" : "Out of Stock");
                        @* đoạn trên là truy cập vào product entity thông qua Vm  *@
                      
                        <tr class="product-row">
                            <td>
                                <div style="display: flex; align-items: center;">
                                    @if (!string.IsNullOrEmpty(item.Image))
                                    {
                                        <img src="@item.Image" alt="@item.Name" />
                                    }
                                    else
                                    {
                                        <img src="~/img/no-img.jfif" alt="Default" />
                                    }
                                    <p>@item.Name</p>
                                </div>
                            </td>
                            <td>@item.Price.ToString("#,##0") đ</td>
                            <td>@item.Brand</td>
                            <td>@item.Stock</td>
                            <td>
                                <span class="status @statusClass">
                                    @statusText
                                </span>
                            </td>
                            <td class="btn-Edit-Delete-Detail">
                                <a asp-action="Edit" asp-route-id="@item.Id"><i class='bx bx-edit-alt'></i></a>
                                <a asp-action="Detail" asp-route-id="@item.Id"><i class='bx bx-show'></i></a>
                                <a href="javascript:void(0)" onclick="confirmDelete(@item.Id, '@item.Name')"><i class='bx bx-trash'></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <form id="deleteForm" method="post" asp-action="Delete">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="deleteId" />
            </form>

            @await Html.PartialAsync("pagination_table", Model)
        </div>
    </div>
</main>

@section Scripts {
    <script>
        function confirmDelete(id, name) {
            showGlobalModal({
                title: 'Xác nhận xóa',
                content: `Bạn có chắc chắn muốn xóa sản phẩm <strong>${name}</strong>? Hành động này không thể hoàn tác.`,
                confirmText: 'Xóa vĩnh viễn',
                cancelText: 'Hủy',
                onConfirm: function () {
                    document.getElementById('deleteId').value = id;
                    document.getElementById('deleteForm').submit();
                }
            });
        }
    </script>
}
