@model Getdata1.Models.Product

@{
    ViewData["Title"] = "Delete Product";
}

@section Styles {
    <style>
        .delete-card {
            background: var(--bg);
            border-radius: var(--card-r);
            border: 0.5px solid var(--border);
            overflow: hidden;
            display: grid;
            grid-template-columns: 1fr 1.2fr;
            gap: 0;
            position: relative;
        }

        .delete-warning-banner {
            grid-column: span 2;
            background: #fff0f0;
            color: #ff3b30;
            padding: 16px 32px;
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 600;
            font-size: 14px;
            border-bottom: 0.5px solid #ffcccc;
        }

        .delete-image-side {
            background: var(--bg2);
            padding: 40px;
            display: flex;
            flex-direction: column;
            align-items: center;
            border-right: 0.5px solid var(--border);
            opacity: 0.8;
        }

        .main-img-container {
            width: 100%;
            aspect-ratio: 1/1;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #fff;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        }

        .main-img-container img {
            max-width: 90%;
            max-height: 90%;
            object-fit: contain;
        }

        .delete-info-side {
            padding: 48px;
            display: flex;
            flex-direction: column;
        }

        .info-header {
            margin-bottom: 32px;
        }

        .brand-tag {
            display: inline-block;
            padding: 4px 12px;
            background: var(--bg3);
            color: var(--sub);
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 12px;
        }

        .product-name {
            font-family: 'Syne', sans-serif;
            font-size: 28px;
            font-weight: 800;
            letter-spacing: -1px;
            margin-bottom: 8px;
            color: var(--text);
        }

        .delete-prompt {
            font-size: 15px;
            color: var(--sub);
            margin-bottom: 32px;
            line-height: 1.6;
        }

        .summary-box {
            background: var(--bg2);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 40px;
        }

        .summary-item {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 0.5px solid var(--border);
        }

        .summary-item:last-child {
            border-bottom: none;
        }

        .summary-label {
            font-size: 12px;
            color: var(--muted);
            font-weight: 500;
        }

        .summary-value {
            font-size: 13px;
            font-weight: 600;
            color: var(--text);
        }

        .delete-actions {
            margin-top: auto;
            display: flex;
            align-items: center;
            gap: 16px;
            padding-top: 32px;
            border-top: 0.5px solid var(--border);
        }

        .btn-confirm-delete {
            background: #ff3b30;
            color: #fff;
            padding: 12px 32px;
            border: none;
            border-radius: 24px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
        }

        .btn-confirm-delete:hover {
            background: #d70015;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(255, 59, 48, 0.2);
        }

        .btn-cancel-link {
            color: var(--sub);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .btn-cancel-link:hover {
            color: var(--text);
        }

        @@media (max-width: 1024px) {
            .delete-card {
                grid-template-columns: 1fr;
            }
            .delete-image-side {
                border-right: none;
                border-bottom: 0.5px solid var(--border);
            }
            .delete-warning-banner {
                grid-column: span 1;
            }
        }

        @@media (max-width: 576px) {
            .delete-info-side {
                padding: 32px 24px;
            }
        }
    </style>
}

<main>
    <div class="head-title">
        <div class="left">
            <h1>Delete Product</h1>
            <ul class="Breakcrumb">
                <li><a asp-action="Index">Inventory</a></li>
                <li><i class='bx bx-chevron-right'></i></li>
                <li><a class="active">Confirm Deletion</a></li>
            </ul>
        </div>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        
        <div class="delete-card">
            <div class="delete-warning-banner">
                <i class='bx bx-error-circle'></i>
                <span>This action cannot be undone. Are you sure you want to delete this product?</span>
            </div>

            <!-- IMAGE SIDE -->
            <div class="delete-image-side">
                <div class="main-img-container">
                    <img src="@(string.IsNullOrEmpty(Model.Image) ? "/img/no-img.jfif" : Model.Image)" alt="@Model.Name">
                </div>
            </div>

            <!-- INFO SIDE -->
            <div class="delete-info-side">
                <div class="info-header">
                    @if (!string.IsNullOrEmpty(Model.Brand))
                    {
                        <span class="brand-tag">@Model.Brand</span>
                    }
                    <h1 class="product-name">@Model.Name</h1>
                </div>

                <p class="delete-prompt">
                    Deleting this product will remove it permanently from the inventory. 
                    Please confirm that you want to proceed.
                </p>

                <div class="summary-box">
                    <div class="summary-item">
                        <span class="summary-label">SKU</span>
                        <span class="summary-value">PROD-@Model.Id.ToString("D5")</span>
                    </div>
                    <div class="summary-item">
                        <span class="summary-label">Price</span>
                        <span class="summary-value">@Model.Price.ToString("#,##0") ₫</span>
                    </div>
                    <div class="summary-item">
                        <span class="summary-label">Current Stock</span>
                        <span class="summary-value">@Model.Stock Units</span>
                    </div>
                </div>

                <div class="delete-actions">
                    <button type="submit" class="btn-confirm-delete">
                        <i class='bx bx-trash'></i> Delete Permanently
                    </button>
                    <a asp-action="Index" class="btn-cancel-link">
                        Cancel and Go Back
                    </a>
                </div>
            </div>
        </div>
    </form>
</main>